<?xml version="1.0" encoding="UTF-8"?>
<!-- Tinklepad Source Selection - Golden Eagle Theme (v1.9.7 readability fix) -->
<!-- Full opaque black background; poster left + plot, scrollable source list right -->
<window type="dialog" id="1200">
    <defaultcontrol always="true">1000</defaultcontrol>
    <zorder>1</zorder>
    <animation effect="fade" time="300">WindowOpen</animation>
    <animation effect="fade" time="200">WindowClose</animation>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>
    <controls>

        <!-- ====== FULL OPAQUE BLACK BACKGROUND ====== -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture>common/black.png</texture>
        </control>

        <!-- ====== Outer Gold Frame ====== -->
        <control type="image">
            <posx>30</posx>
            <posy>30</posy>
            <width>1860</width>
            <height>1020</height>
            <texture border="2" colordiffuse="FFFFD700">common/white.png</texture>
        </control>
        <control type="image">
            <posx>33</posx>
            <posy>33</posy>
            <width>1854</width>
            <height>1014</height>
            <texture>common/black.png</texture>
        </control>

        <!-- ====== TOP HEADER ====== -->
        <control type="label">
            <posx>60</posx>
            <posy>55</posy>
            <width>500</width>
            <height>55</height>
            <label>[B]TINKLEPAD[/B]</label>
            <font>font37</font>
            <textcolor>FFFFD700</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        <control type="label">
            <posx>60</posx>
            <posy>110</posy>
            <width>500</width>
            <height>26</height>
            <label>SELECT YOUR LINK</label>
            <font>font12</font>
            <textcolor>FFAAAAAA</textcolor>
            <align>left</align>
        </control>

        <!-- Section title -->
        <control type="label">
            <posx>560</posx>
            <posy>70</posy>
            <width>1300</width>
            <height>50</height>
            <label>[B]SELECT A LINK[/B]</label>
            <font>font30</font>
            <textcolor>FFFFD700</textcolor>
            <align>center</align>
            <aligny>center</aligny>
        </control>

        <!-- Movie/show title -->
        <control type="label" id="300">
            <posx>560</posx>
            <posy>118</posy>
            <width>1300</width>
            <height>34</height>
            <label>$INFO[Window.Property(title)]</label>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>center</align>
        </control>

        <control type="image">
            <posx>60</posx>
            <posy>160</posy>
            <width>1800</width>
            <height>2</height>
            <texture colordiffuse="55FFD700">common/white.png</texture>
        </control>

        <!-- ====== LEFT - POSTER + PLOT ====== -->
        <!-- Poster border -->
        <control type="image">
            <posx>57</posx>
            <posy>187</posy>
            <width>406</width>
            <height>606</height>
            <texture colordiffuse="FFFFD700">common/white.png</texture>
        </control>
        <control type="image" id="200">
            <posx>60</posx>
            <posy>190</posy>
            <width>400</width>
            <height>600</height>
            <texture>$INFO[Window.Property(poster)]</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- Plot heading -->
        <control type="label">
            <posx>60</posx>
            <posy>810</posy>
            <width>400</width>
            <height>26</height>
            <label>[B]PLOT[/B]</label>
            <font>font12</font>
            <textcolor>FFFFD700</textcolor>
            <align>left</align>
        </control>
        <!-- Plot text -->
        <control type="textbox" id="303">
            <posx>60</posx>
            <posy>838</posy>
            <width>400</width>
            <height>200</height>
            <font>font12</font>
            <textcolor>FFEEEEEE</textcolor>
            <align>left</align>
            <label>$INFO[Window.Property(plot)]</label>
        </control>

        <!-- ====== STATS PANEL (right of poster top) ====== -->
        <control type="label">
            <posx>500</posx>
            <posy>190</posy>
            <width>320</width>
            <height>28</height>
            <label>[B]SOURCES FOUND[/B]</label>
            <font>font12</font>
            <textcolor>FFFFD700</textcolor>
            <align>left</align>
        </control>
        <control type="label" id="201">
            <posx>500</posx>
            <posy>222</posy>
            <width>320</width>
            <height>60</height>
            <label>$INFO[Window.Property(total_sources)]</label>
            <font>font45</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>left</align>
            <aligny>top</aligny>
        </control>

        <!-- Quality breakdown line (single row, comma separated) -->
        <control type="label" id="202">
            <posx>500</posx>
            <posy>290</posy>
            <width>900</width>
            <height>26</height>
            <label>$INFO[Window.Property(quality_4k)]</label>
            <font>font12</font>
            <textcolor>FFFF4444</textcolor>
            <align>left</align>
        </control>
        <control type="label" id="203">
            <posx>620</posx>
            <posy>290</posy>
            <width>900</width>
            <height>26</height>
            <label>$INFO[Window.Property(quality_1080p)]</label>
            <font>font12</font>
            <textcolor>FF00FF00</textcolor>
            <align>left</align>
        </control>
        <control type="label" id="204">
            <posx>760</posx>
            <posy>290</posy>
            <width>900</width>
            <height>26</height>
            <label>$INFO[Window.Property(quality_720p)]</label>
            <font>font12</font>
            <textcolor>FF4488FF</textcolor>
            <align>left</align>
        </control>
        <control type="label" id="205">
            <posx>880</posx>
            <posy>290</posy>
            <width>900</width>
            <height>26</height>
            <label>$INFO[Window.Property(quality_sd)]</label>
            <font>font12</font>
            <textcolor>FFAAAAAA</textcolor>
            <align>left</align>
        </control>

        <!-- Debrid status -->
        <control type="label" id="206">
            <posx>500</posx>
            <posy>318</posy>
            <width>1360</width>
            <height>26</height>
            <label>$INFO[Window.Property(debrid_status)]</label>
            <font>font10</font>
            <textcolor>FF888888</textcolor>
            <align>left</align>
        </control>

        <!-- ====== SOURCE LIST ====== -->
        <!-- List panel background -->
        <control type="image">
            <posx>500</posx>
            <posy>355</posy>
            <width>1360</width>
            <height>545</height>
            <texture colordiffuse="55000000">common/black.png</texture>
            <bordertexture border="2" colordiffuse="44FFD700">common/white.png</bordertexture>
        </control>

        <control type="list" id="1000">
            <posx>510</posx>
            <posy>365</posy>
            <width>1320</width>
            <height>525</height>
            <orientation>vertical</orientation>
            <pagecontrol>1001</pagecontrol>
            <scrolltime>200</scrolltime>
            <ondown>501</ondown>

            <itemlayout height="74">
                <control type="image">
                    <posx>0</posx>
                    <posy>2</posy>
                    <width>1300</width>
                    <height>68</height>
                    <texture colordiffuse="22FFFFFF">common/white.png</texture>
                </control>
                <control type="label">
                    <posx>20</posx>
                    <posy>8</posy>
                    <width>720</width>
                    <height>32</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font14</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <control type="label">
                    <posx>20</posx>
                    <posy>42</posy>
                    <width>720</width>
                    <height>24</height>
                    <label>$INFO[ListItem.Property(source_type)]</label>
                    <font>font10</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <align>left</align>
                </control>
                <!-- Quality Badge -->
                <control type="image">
                    <posx>760</posx>
                    <posy>17</posy>
                    <width>110</width>
                    <height>38</height>
                    <texture colordiffuse="$INFO[ListItem.Property(quality_color)]">common/white.png</texture>
                    <bordertexture border="2" colordiffuse="FFFFD700">common/white.png</bordertexture>
                </control>
                <control type="label">
                    <posx>760</posx>
                    <posy>17</posy>
                    <width>110</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font13_title</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Size -->
                <control type="label">
                    <posx>890</posx>
                    <posy>17</posy>
                    <width>150</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(size)]</label>
                    <font>font13</font>
                    <textcolor>FFAAAAAA</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Host -->
                <control type="label">
                    <posx>1050</posx>
                    <posy>17</posy>
                    <width>230</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(host)]</label>
                    <font>font12</font>
                    <textcolor>FF888888</textcolor>
                    <align>right</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>

            <focusedlayout height="74">
                <control type="image">
                    <posx>0</posx>
                    <posy>2</posy>
                    <width>1300</width>
                    <height>68</height>
                    <texture colordiffuse="55FFD700">common/white.png</texture>
                    <bordertexture border="3" colordiffuse="FFFFD700">common/white.png</bordertexture>
                </control>
                <control type="label">
                    <posx>20</posx>
                    <posy>8</posy>
                    <width>720</width>
                    <height>32</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font14</font>
                    <textcolor>FFFFD700</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <control type="label">
                    <posx>20</posx>
                    <posy>42</posy>
                    <width>720</width>
                    <height>24</height>
                    <label>$INFO[ListItem.Property(source_type)]</label>
                    <font>font10</font>
                    <textcolor>FFEEEEEE</textcolor>
                    <align>left</align>
                </control>
                <control type="image">
                    <posx>760</posx>
                    <posy>17</posy>
                    <width>110</width>
                    <height>38</height>
                    <texture colordiffuse="FFFFD700">common/white.png</texture>
                </control>
                <control type="label">
                    <posx>760</posx>
                    <posy>17</posy>
                    <width>110</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font13_title</font>
                    <textcolor>FF000000</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <control type="label">
                    <posx>890</posx>
                    <posy>17</posy>
                    <width>150</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(size)]</label>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <control type="label">
                    <posx>1050</posx>
                    <posy>17</posy>
                    <width>230</width>
                    <height>38</height>
                    <label>$INFO[ListItem.Property(host)]</label>
                    <font>font12</font>
                    <textcolor>FFEEEEEE</textcolor>
                    <align>right</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>

        <!-- Scrollbar -->
        <control type="scrollbar" id="1001">
            <posx>1835</posx>
            <posy>365</posy>
            <width>12</width>
            <height>525</height>
            <orientation>vertical</orientation>
            <texturesliderbackground colordiffuse="22FFFFFF">common/white.png</texturesliderbackground>
            <texturesliderbar colordiffuse="FFFFD700">common/white.png</texturesliderbar>
        </control>

        <!-- Cancel Button -->
        <control type="button" id="501">
            <posx>810</posx>
            <posy>930</posy>
            <width>300</width>
            <height>70</height>
            <label>[B]CANCEL[/B]</label>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FFFFD700">common/white.png</texturefocus>
            <texturenofocus colordiffuse="33FFFFFF">common/white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>1000</onup>
        </control>

        <!-- Nav hint -->
        <control type="label">
            <posx>60</posx>
            <posy>1010</posy>
            <width>1800</width>
            <height>24</height>
            <label>SELECT to play  •  BACK to cancel</label>
            <font>font10</font>
            <textcolor>FF777777</textcolor>
            <align>center</align>
        </control>
    </controls>
</window>
