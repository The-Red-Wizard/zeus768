<?xml version="1.0" encoding="UTF-8"?>
<!-- Tinklepad Source Search - Golden Eagle Theme -->
<!-- Based on mockup: Golden theme with animated spinner, provider progress bars -->
<window type="dialog" id="1100">
    <defaultcontrol always="true">550</defaultcontrol>
    <zorder>1</zorder>
    <animation effect="fade" time="400">WindowOpen</animation>
    <animation effect="fade" time="300">WindowClose</animation>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>
    <controls>
        <!-- Full-screen Fanart Background -->
        <control type="image" id="100">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture background="true">$INFO[Window.Property(fanart)]</texture>
            <aspectratio>scale</aspectratio>
            <animation effect="fade" start="0" end="100" time="600">WindowOpen</animation>
        </control>
        
        <!-- Dark Overlay with Golden Tint -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="E5000000">common/black.png</texture>
        </control>
        
        <!-- Subtle Golden Gradient Overlay -->
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="11FFD700">common/white.png</texture>
        </control>
        
        <!-- Left Branding Panel -->
        <control type="group">
            <posx>0</posx>
            <posy>0</posy>
            <animation effect="slide" start="-350,0" end="0,0" time="500" tween="cubic" easing="out">WindowOpen</animation>
            
            <!-- Dark Panel Background -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>350</width>
                <height>1080</height>
                <texture colordiffuse="F0050505">common/black.png</texture>
            </control>
            
            <!-- Gold Accent Line -->
            <control type="image">
                <posx>348</posx>
                <posy>0</posy>
                <width>2</width>
                <height>1080</height>
                <texture colordiffuse="FFFFD700">common/white.png</texture>
            </control>
            
            <!-- Gold Decorative Top Line -->
            <control type="image">
                <posx>40</posx>
                <posy>80</posy>
                <width>270</width>
                <height>2</height>
                <texture colordiffuse="88FFD700">common/white.png</texture>
            </control>
            
            <!-- TINKLEPAD Branding -->
            <control type="label">
                <posx>20</posx>
                <posy>100</posy>
                <width>310</width>
                <height>60</height>
                <label>[B]TINKLEPAD[/B]</label>
                <font>font37</font>
                <textcolor>FFFFD700</textcolor>
                <shadowcolor>88000000</shadowcolor>
                <align>center</align>
            </control>
            
            <control type="label">
                <posx>20</posx>
                <posy>165</posy>
                <width>310</width>
                <height>30</height>
                <label>SOURCE LINK SEARCH</label>
                <font>font12</font>
                <textcolor>FFAAAAAA</textcolor>
                <align>center</align>
            </control>
            
            <!-- Gold Decorative Line -->
            <control type="image">
                <posx>40</posx>
                <posy>210</posy>
                <width>270</width>
                <height>2</height>
                <texture colordiffuse="55FFD700">common/white.png</texture>
            </control>
            
            <!-- Poster Image -->
            <control type="image" id="200">
                <posx>50</posx>
                <posy>240</posy>
                <width>250</width>
                <height>375</height>
                <texture>$INFO[Window.Property(poster)]</texture>
                <aspectratio>keep</aspectratio>
                <bordertexture border="3" colordiffuse="FFFFD700">common/white.png</bordertexture>
                <bordersize>3</bordersize>
            </control>
            
            <!-- Content Info Below Poster -->
            <control type="label" id="300">
                <posx>20</posx>
                <posy>640</posy>
                <width>310</width>
                <height>45</height>
                <label>$INFO[Window.Property(title)]</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
                <align>center</align>
                <wrapmultiline>true</wrapmultiline>
            </control>
            
            <control type="label" id="301">
                <posx>20</posx>
                <posy>690</posy>
                <width>310</width>
                <height>25</height>
                <label>$INFO[Window.Property(meta_line)]</label>
                <font>font10</font>
                <textcolor>FFFFD700</textcolor>
                <align>center</align>
            </control>
            
            <control type="label" id="302">
                <posx>20</posx>
                <posy>720</posy>
                <width>310</width>
                <height>25</height>
                <label>$INFO[Window.Property(genres)]</label>
                <font>font10</font>
                <textcolor>FF888888</textcolor>
                <align>center</align>
            </control>
        </control>
        
        <!-- Main Content Area - Search Progress -->
        <control type="group">
            <posx>400</posx>
            <posy>120</posy>
            <animation effect="slide" start="100,0" end="0,0" time="500" delay="100" tween="cubic" easing="out">WindowOpen</animation>
            <animation effect="fade" start="0" end="100" time="400" delay="100">WindowOpen</animation>
            
            <!-- Main Panel Background with Gold Border -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1420</width>
                <height>740</height>
                <texture colordiffuse="CC080808">common/black.png</texture>
                <bordertexture border="2" colordiffuse="AAFFD700">common/white.png</bordertexture>
            </control>
            
            <!-- Header: SEARCHING SOURCES FOR LINKS... -->
            <control type="label" id="501">
                <posx>0</posx>
                <posy>25</posy>
                <width>1420</width>
                <height>50</height>
                <label>[B]SEARCHING SOURCES FOR LINKS...[/B]</label>
                <font>font30</font>
                <textcolor>FFFFD700</textcolor>
                <shadowcolor>88000000</shadowcolor>
                <align>center</align>
            </control>
            
            <!-- Decorative Line Under Header -->
            <control type="image">
                <posx>100</posx>
                <posy>85</posy>
                <width>1220</width>
                <height>2</height>
                <texture colordiffuse="44FFD700">common/white.png</texture>
            </control>
            
            <!-- Animated Golden Spinner/Orb (Right Side) -->
            <control type="group">
                <posx>950</posx>
                <posy>180</posy>
                
                <!-- Outer Ring - Slow Rotation -->
                <control type="image">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>280</height>
                    <texture colordiffuse="33FFD700">common/white.png</texture>
                    <aspectratio>keep</aspectratio>
                    <animation effect="rotate" start="0" end="360" time="8000" loop="true" center="140,140">Conditional</animation>
                    <animation effect="fade" start="30" end="70" time="2000" loop="true" reversible="true">Conditional</animation>
                    <visible>true</visible>
                </control>
                
                <!-- Middle Ring - Medium Rotation (Opposite) -->
                <control type="image">
                    <posx>40</posx>
                    <posy>40</posy>
                    <width>200</width>
                    <height>200</height>
                    <texture colordiffuse="55FFD700">common/white.png</texture>
                    <aspectratio>keep</aspectratio>
                    <animation effect="rotate" start="360" end="0" time="5000" loop="true" center="100,100">Conditional</animation>
                    <animation effect="fade" start="50" end="90" time="1500" loop="true" reversible="true" delay="300">Conditional</animation>
                    <visible>true</visible>
                </control>
                
                <!-- Inner Ring - Fast Rotation -->
                <control type="image">
                    <posx>80</posx>
                    <posy>80</posy>
                    <width>120</width>
                    <height>120</height>
                    <texture colordiffuse="88FFD700">common/white.png</texture>
                    <aspectratio>keep</aspectratio>
                    <animation effect="rotate" start="0" end="360" time="2500" loop="true" center="60,60">Conditional</animation>
                    <visible>true</visible>
                </control>
                
                <!-- Center Pulse (Golden Core) -->
                <control type="image">
                    <posx>110</posx>
                    <posy>110</posy>
                    <width>60</width>
                    <height>60</height>
                    <texture colordiffuse="FFFFD700">common/white.png</texture>
                    <aspectratio>keep</aspectratio>
                    <animation effect="zoom" start="80" end="120" time="1200" loop="true" reversible="true" center="30,30">Conditional</animation>
                    <animation effect="fade" start="70" end="100" time="1200" loop="true" reversible="true">Conditional</animation>
                    <visible>true</visible>
                </control>
                
                <!-- Orbiting Particle 1 -->
                <control type="image">
                    <posx>130</posx>
                    <posy>10</posy>
                    <width>20</width>
                    <height>20</height>
                    <texture colordiffuse="FFFFD700">common/white.png</texture>
                    <animation effect="rotate" start="0" end="360" time="3000" loop="true" center="10,130">Conditional</animation>
                    <visible>true</visible>
                </control>
                
                <!-- Orbiting Particle 2 -->
                <control type="image">
                    <posx>130</posx>
                    <posy>250</posy>
                    <width>20</width>
                    <height>20</height>
                    <texture colordiffuse="FFFFD700">common/white.png</texture>
                    <animation effect="rotate" start="180" end="540" time="3000" loop="true" center="10,-110">Conditional</animation>
                    <visible>true</visible>
                </control>
            </control>
            
            <!-- Provider Search List Container (Left Side) -->
            <control type="group">
                <posx>60</posx>
                <posy>120</posy>
                
                <!-- Provider Row 1: FREE STREAMS -->
                <control type="group">
                    <posx>0</posx>
                    <posy>0</posy>
                    
                    <!-- Provider Icon Box -->
                    <control type="image">
                        <posx>0</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>50</height>
                        <texture colordiffuse="44FFD700">common/white.png</texture>
                        <bordertexture border="1" colordiffuse="FFFFD700">common/white.png</bordertexture>
                    </control>
                    
                    <!-- Provider Name -->
                    <control type="label">
                        <posx>70</posx>
                        <posy>0</posy>
                        <width>400</width>
                        <height>35</height>
                        <label>[B]FREE STREAMS[/B]</label>
                        <font>font14</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <shadowcolor>88000000</shadowcolor>
                        <align>left</align>
                    </control>
                    
                    <!-- Progress Bar Background -->
                    <control type="image">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>400</width>
                        <height>14</height>
                        <texture colordiffuse="22FFD700">common/white.png</texture>
                    </control>
                    
                    <!-- Progress Bar Fill - Animated -->
                    <control type="image" id="610">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>300</width>
                        <height>14</height>
                        <texture colordiffuse="CCFFD700">common/white.png</texture>
                        <animation effect="slide" start="-300,0" end="0,0" time="1500">WindowOpen</animation>
                    </control>
                    
                    <!-- Status Label -->
                    <control type="label" id="611">
                        <posx>500</posx>
                        <posy>12</posy>
                        <width>250</width>
                        <height>30</height>
                        <label>$INFO[Window.Property(free_status)]</label>
                        <font>font12</font>
                        <textcolor>FF00FF00</textcolor>
                        <align>right</align>
                    </control>
                </control>
                
                <!-- Provider Row 2: DDL SOURCES -->
                <control type="group">
                    <posx>0</posx>
                    <posy>85</posy>
                    
                    <control type="image">
                        <posx>0</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>50</height>
                        <texture colordiffuse="44FFD700">common/white.png</texture>
                        <bordertexture border="1" colordiffuse="FFFFD700">common/white.png</bordertexture>
                    </control>
                    
                    <control type="label">
                        <posx>70</posx>
                        <posy>0</posy>
                        <width>400</width>
                        <height>35</height>
                        <label>[B]DDL SOURCES[/B]</label>
                        <font>font14</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <shadowcolor>88000000</shadowcolor>
                        <align>left</align>
                    </control>
                    
                    <control type="image">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>400</width>
                        <height>14</height>
                        <texture colordiffuse="22FFD700">common/white.png</texture>
                    </control>
                    
                    <control type="image" id="620">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>220</width>
                        <height>14</height>
                        <texture colordiffuse="CCFFD700">common/white.png</texture>
                        <animation effect="slide" start="-220,0" end="0,0" time="2000" delay="300">WindowOpen</animation>
                    </control>
                    
                    <control type="label" id="621">
                        <posx>500</posx>
                        <posy>12</posy>
                        <width>250</width>
                        <height>30</height>
                        <label>$INFO[Window.Property(ddl_status)]</label>
                        <font>font12</font>
                        <textcolor>FFFFD700</textcolor>
                        <align>right</align>
                    </control>
                </control>
                
                <!-- Provider Row 3: TORRENT SOURCES -->
                <control type="group">
                    <posx>0</posx>
                    <posy>170</posy>
                    
                    <control type="image">
                        <posx>0</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>50</height>
                        <texture colordiffuse="44FFD700">common/white.png</texture>
                        <bordertexture border="1" colordiffuse="FFFFD700">common/white.png</bordertexture>
                    </control>
                    
                    <control type="label">
                        <posx>70</posx>
                        <posy>0</posy>
                        <width>400</width>
                        <height>35</height>
                        <label>[B]TORRENT SOURCES[/B]</label>
                        <font>font14</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <shadowcolor>88000000</shadowcolor>
                        <align>left</align>
                    </control>
                    
                    <control type="image">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>400</width>
                        <height>14</height>
                        <texture colordiffuse="22FFD700">common/white.png</texture>
                    </control>
                    
                    <control type="image" id="630">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>150</width>
                        <height>14</height>
                        <texture colordiffuse="CCFFD700">common/white.png</texture>
                        <animation effect="slide" start="-150,0" end="0,0" time="2500" delay="600">WindowOpen</animation>
                    </control>
                    
                    <control type="label" id="631">
                        <posx>500</posx>
                        <posy>12</posy>
                        <width>250</width>
                        <height>30</height>
                        <label>$INFO[Window.Property(torrent_status)]</label>
                        <font>font12</font>
                        <textcolor>FFFF8800</textcolor>
                        <align>right</align>
                    </control>
                </control>
                
                <!-- Provider Row 4: PREMIUM HOSTS -->
                <control type="group">
                    <posx>0</posx>
                    <posy>255</posy>
                    
                    <control type="image">
                        <posx>0</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>50</height>
                        <texture colordiffuse="44FFD700">common/white.png</texture>
                        <bordertexture border="1" colordiffuse="FFFFD700">common/white.png</bordertexture>
                    </control>
                    
                    <control type="label">
                        <posx>70</posx>
                        <posy>0</posy>
                        <width>400</width>
                        <height>35</height>
                        <label>[B]PREMIUM HOSTS[/B]</label>
                        <font>font14</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <shadowcolor>88000000</shadowcolor>
                        <align>left</align>
                    </control>
                    
                    <control type="image">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>400</width>
                        <height>14</height>
                        <texture colordiffuse="22FFD700">common/white.png</texture>
                    </control>
                    
                    <control type="image" id="640">
                        <posx>70</posx>
                        <posy>38</posy>
                        <width>100</width>
                        <height>14</height>
                        <texture colordiffuse="CCFFD700">common/white.png</texture>
                        <animation effect="slide" start="-100,0" end="0,0" time="3000" delay="900">WindowOpen</animation>
                    </control>
                    
                    <control type="label" id="641">
                        <posx>500</posx>
                        <posy>12</posy>
                        <width>250</width>
                        <height>30</height>
                        <label>$INFO[Window.Property(premium_status)]</label>
                        <font>font12</font>
                        <textcolor>FF888888</textcolor>
                        <align>right</align>
                    </control>
                </control>
            </control>
            
            <!-- Overall Progress Section -->
            <control type="group">
                <posx>60</posx>
                <posy>480</posy>
                
                <!-- Current Provider Being Searched -->
                <control type="label" id="502">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>800</width>
                    <height>30</height>
                    <label>$INFO[Window.Property(current_provider)]</label>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <shadowcolor>88000000</shadowcolor>
                    <align>left</align>
                    <scroll>true</scroll>
                </control>
                
                <!-- Total Sources Counter -->
                <control type="label" id="503">
                    <posx>0</posx>
                    <posy>35</posy>
                    <width>800</width>
                    <height>45</height>
                    <label>$INFO[Window.Property(sources_found)]</label>
                    <font>font30</font>
                    <textcolor>FF00FF00</textcolor>
                    <shadowcolor>88000000</shadowcolor>
                    <align>left</align>
                </control>
                
                <!-- Main Progress Bar Background -->
                <control type="image">
                    <posx>0</posx>
                    <posy>95</posy>
                    <width>800</width>
                    <height>18</height>
                    <texture colordiffuse="22FFFFFF">common/white.png</texture>
                </control>
                
                <!-- Main Progress Bar Fill -->
                <control type="image" id="504">
                    <posx>0</posx>
                    <posy>95</posy>
                    <width>0</width>
                    <height>18</height>
                    <texture colordiffuse="FFFFD700">common/white.png</texture>
                </control>
                
                <!-- Progress Percentage -->
                <control type="label" id="505">
                    <posx>400</posx>
                    <posy>120</posy>
                    <width>100</width>
                    <height>25</height>
                    <label>$INFO[Window.Property(progress_percent)]</label>
                    <font>font12</font>
                    <textcolor>FFFFD700</textcolor>
                    <align>center</align>
                </control>
            </control>
            
            <!-- Bottom Buttons -->
            <control type="group">
                <posx>280</posx>
                <posy>620</posy>
                <animation effect="slide" start="0,100" end="0,0" time="400" delay="200" tween="cubic" easing="out">WindowOpen</animation>
                
                <!-- Cancel Button -->
                <control type="button" id="550">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>300</width>
                    <height>75</height>
                    <label>[B]CANCEL[/B]</label>
                    <font>font14</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FF000000</focusedcolor>
                    <texturefocus colordiffuse="FFFFD700">common/white.png</texturefocus>
                    <texturenofocus colordiffuse="33FFFFFF">common/white.png</texturenofocus>
                    <align>center</align>
                    <onright>551</onright>
                </control>
                
                <!-- View Links Button -->
                <control type="button" id="551">
                    <posx>350</posx>
                    <posy>0</posy>
                    <width>300</width>
                    <height>75</height>
                    <label>[B]VIEW LINKS[/B]</label>
                    <font>font14</font>
                    <textcolor>FF000000</textcolor>
                    <focusedcolor>FF000000</focusedcolor>
                    <texturefocus colordiffuse="FFFFD700">common/white.png</texturefocus>
                    <texturenofocus colordiffuse="AAFFD700">common/white.png</texturenofocus>
                    <align>center</align>
                    <onleft>550</onleft>
                </control>
            </control>
        </control>
        
        <!-- Hidden button for focus management -->
        <control type="button" id="9999">
            <posx>-100</posx>
            <posy>-100</posy>
            <width>1</width>
            <height>1</height>
            <visible>false</visible>
        </control>
    </controls>
</window>
