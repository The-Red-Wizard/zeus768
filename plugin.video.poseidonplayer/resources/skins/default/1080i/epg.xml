<?xml version="1.0" encoding="UTF-8"?>
<!--
    Poseidon Player EPG Guide Skin
    Author: poseidon12
    
    This skin creates a beautiful grid-style TV guide similar to the reference design:
    - Dark teal/blue theme
    - Channel logos and numbers on the left
    - Time slots across the top
    - Program grid with current selection highlight
    - Info panel at top showing selected program details
-->
<window type="window" id="6000">
    <defaultcontrol always="true">50</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>
    
    <!-- Background -->
    <controls>
        <control type="image">
            <posx>0</posx>
            <posy>0</posy>
            <width>1920</width>
            <height>1080</height>
            <texture>fanart.jpg</texture>
            <colordiffuse>FF0A2530</colordiffuse>
        </control>
        
        <!-- Header Bar with Logo -->
        <control type="grouplist" id="1000">
            <posx>40</posx>
            <posy>20</posy>
            <width>1840</width>
            <height>80</height>
            <orientation>horizontal</orientation>
            
            <!-- Logo -->
            <control type="image">
                <width>60</width>
                <height>60</height>
                <texture>icon.png</texture>
            </control>
            
            <!-- Title -->
            <control type="label">
                <posx>20</posx>
                <posy>10</posy>
                <width>400</width>
                <height>50</height>
                <label>POSEIDON PLAYER</label>
                <font>font_title</font>
                <textcolor>FFD4AF37</textcolor>
                <shadowcolor>FF000000</shadowcolor>
            </control>
        </control>
        
        <!-- Info Panel (Top) - Shows selected program details -->
        <control type="group" id="100">
            <posx>40</posx>
            <posy>100</posy>
            <width>1840</width>
            <height>180</height>
            
            <!-- Background -->
            <control type="image">
                <posx>0</posx>
                <posy>0</posy>
                <width>1840</width>
                <height>180</height>
                <texture colordiffuse="CC0F3040">white.png</texture>
                <bordertexture border="2">button-nofocus.png</bordertexture>
                <bordersize>2</bordersize>
            </control>
            
            <!-- Channel Number & Logo -->
            <control type="group">
                <posx>20</posx>
                <posy>20</posy>
                
                <control type="label" id="101">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>80</width>
                    <height>40</height>
                    <label>$INFO[Container(50).ListItem.Property(channel_num)]</label>
                    <font>font28</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                </control>
                
                <control type="image" id="102">
                    <posx>0</posx>
                    <posy>50</posy>
                    <width>100</width>
                    <height>80</height>
                    <texture>$INFO[Container(50).ListItem.Thumb]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
            </control>
            
            <!-- Program Info -->
            <control type="group">
                <posx>150</posx>
                <posy>20</posy>
                
                <!-- Title -->
                <control type="label" id="103">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>1200</width>
                    <height>40</height>
                    <label>$INFO[Container(50).ListItem.Label]</label>
                    <font>font28</font>
                    <textcolor>FF00CED1</textcolor>
                    <align>left</align>
                </control>
                
                <!-- Episode Info -->
                <control type="label" id="104">
                    <posx>0</posx>
                    <posy>45</posy>
                    <width>1200</width>
                    <height>30</height>
                    <label>$INFO[Container(50).ListItem.Property(episode_info)]</label>
                    <font>font14</font>
                    <textcolor>FFFFFFFF</textcolor>
                </control>
                
                <!-- Channel & Time -->
                <control type="label" id="105">
                    <posx>0</posx>
                    <posy>80</posy>
                    <width>1200</width>
                    <height>25</height>
                    <label>$INFO[Container(50).ListItem.Property(channel_name)] | $INFO[Container(50).ListItem.Property(time_slot)]</label>
                    <font>font12</font>
                    <textcolor>FFB0B0B0</textcolor>
                </control>
                
                <!-- Description -->
                <control type="textbox" id="106">
                    <posx>0</posx>
                    <posy>110</posy>
                    <width>1400</width>
                    <height>60</height>
                    <font>font12</font>
                    <textcolor>FFB0B0B0</textcolor>
                    <label>$INFO[Container(50).ListItem.Plot]</label>
                    <autoscroll delay="5000" time="1000" repeat="5000">true</autoscroll>
                </control>
            </control>
            
            <!-- Logo on Right -->
            <control type="image">
                <posx>1680</posx>
                <posy>20</posy>
                <width>140</width>
                <height>140</height>
                <texture>icon.png</texture>
                <aspectratio>keep</aspectratio>
                <colordiffuse>FF00CED1</colordiffuse>
            </control>
        </control>
        
        <!-- Time Slot Headers -->
        <control type="grouplist" id="200">
            <posx>200</posx>
            <posy>300</posy>
            <width>1700</width>
            <height>40</height>
            <orientation>horizontal</orientation>
            <itemgap>0</itemgap>
            
            <!-- Time slots are dynamically updated -->
            <control type="label" id="201">
                <width>283</width>
                <height>40</height>
                <label>09:00</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
            <control type="label" id="202">
                <width>283</width>
                <height>40</height>
                <label>09:30</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
            <control type="label" id="203">
                <width>283</width>
                <height>40</height>
                <label>10:00</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
            <control type="label" id="204">
                <width>283</width>
                <height>40</height>
                <label>10:30</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
            <control type="label" id="205">
                <width>283</width>
                <height>40</height>
                <label>11:00</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
            <control type="label" id="206">
                <width>285</width>
                <height>40</height>
                <label>11:30</label>
                <font>font16</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
            </control>
        </control>
        
        <!-- Current Time Indicator Line -->
        <control type="image" id="250">
            <posx>450</posx>
            <posy>300</posy>
            <width>2</width>
            <height>680</height>
            <texture colordiffuse>FFFFFF00</texture>
        </control>
        
        <!-- Channel List (Left Side) -->
        <control type="fixedlist" id="50">
            <posx>40</posx>
            <posy>350</posy>
            <width>160</width>
            <height>650</height>
            <orientation>vertical</orientation>
            <movement>2</movement>
            <focusposition>2</focusposition>
            <pagecontrol>60</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemlayout width="160" height="100">
                <control type="group">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>160</width>
                    <height>100</height>
                    
                    <!-- Background -->
                    <control type="image">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>160</width>
                        <height>95</height>
                        <texture colordiffuse="880F3040">white.png</texture>
                    </control>
                    
                    <!-- Channel Number -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>25</height>
                        <label>$INFO[ListItem.Property(channel_num)]</label>
                        <font>font16</font>
                        <textcolor>FFFFFFFF</textcolor>
                    </control>
                    
                    <!-- Channel Logo -->
                    <control type="image">
                        <posx>10</posx>
                        <posy>35</posy>
                        <width>140</width>
                        <height>55</height>
                        <texture>$INFO[ListItem.Thumb]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                </control>
            </itemlayout>
            <focusedlayout width="160" height="100">
                <control type="group">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>160</width>
                    <height>100</height>
                    
                    <!-- Focused Background -->
                    <control type="image">
                        <posx>0</posx>
                        <posy>0</posy>
                        <width>160</width>
                        <height>95</height>
                        <texture colordiffuse="FF00CED1">white.png</texture>
                    </control>
                    
                    <!-- Channel Number -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>5</posy>
                        <width>50</width>
                        <height>25</height>
                        <label>$INFO[ListItem.Property(channel_num)]</label>
                        <font>font16_bold</font>
                        <textcolor>FF0A2530</textcolor>
                    </control>
                    
                    <!-- Channel Logo -->
                    <control type="image">
                        <posx>10</posx>
                        <posy>35</posy>
                        <width>140</width>
                        <height>55</height>
                        <texture>$INFO[ListItem.Thumb]</texture>
                        <aspectratio>keep</aspectratio>
                    </control>
                </control>
            </focusedlayout>
            <onup>50</onup>
            <ondown>50</ondown>
            <onleft>50</onleft>
            <onright>51</onright>
        </control>
        
        <!-- EPG Grid (Program Cells) -->
        <control type="panel" id="51">
            <posx>200</posx>
            <posy>350</posy>
            <width>1700</width>
            <height>650</height>
            <orientation>horizontal</orientation>
            <pagecontrol>61</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemlayout width="283" height="100">
                <control type="group">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>95</height>
                    
                    <!-- Cell Background -->
                    <control type="image">
                        <posx>2</posx>
                        <posy>2</posy>
                        <width>276</width>
                        <height>91</height>
                        <texture colordiffuse="880F3040">white.png</texture>
                        <bordertexture border="1" colordiffuse="44FFFFFF">white.png</bordertexture>
                    </control>
                    
                    <!-- Program Title -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>10</posy>
                        <width>260</width>
                        <height>35</height>
                        <label>$INFO[ListItem.Label]</label>
                        <font>font14</font>
                        <textcolor>FFFFFFFF</textcolor>
                        <align>left</align>
                    </control>
                    
                    <!-- Channel Name / Category -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>50</posy>
                        <width>260</width>
                        <height>25</height>
                        <label>$INFO[ListItem.Property(channel_name)]</label>
                        <font>font12</font>
                        <textcolor>FF808080</textcolor>
                        <align>left</align>
                    </control>
                </control>
            </itemlayout>
            <focusedlayout width="283" height="100">
                <control type="group">
                    <posx>0</posx>
                    <posy>0</posy>
                    <width>280</width>
                    <height>95</height>
                    
                    <!-- Focused Cell Background - Bright Teal -->
                    <control type="image">
                        <posx>2</posx>
                        <posy>2</posy>
                        <width>276</width>
                        <height>91</height>
                        <texture colordiffuse="FF00CED1">white.png</texture>
                        <bordertexture border="2" colordiffuse="FFFFFFFF">white.png</bordertexture>
                    </control>
                    
                    <!-- Program Title -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>10</posy>
                        <width>260</width>
                        <height>35</height>
                        <label>$INFO[ListItem.Label]</label>
                        <font>font14_bold</font>
                        <textcolor>FF0A2530</textcolor>
                        <align>left</align>
                    </control>
                    
                    <!-- Channel Name -->
                    <control type="label">
                        <posx>10</posx>
                        <posy>50</posy>
                        <width>260</width>
                        <height>25</height>
                        <label>$INFO[ListItem.Property(channel_name)]</label>
                        <font>font12</font>
                        <textcolor>FF0A2530</textcolor>
                        <align>left</align>
                    </control>
                </control>
            </focusedlayout>
            <onup>51</onup>
            <ondown>51</ondown>
            <onleft>50</onleft>
            <onright>51</onright>
        </control>
        
        <!-- Scrollbar for Channels -->
        <control type="scrollbar" id="60">
            <posx>5</posx>
            <posy>350</posy>
            <width>25</width>
            <height>650</height>
            <orientation>vertical</orientation>
            <texturesliderbackground colordiffuse="44FFFFFF">white.png</texturesliderbackground>
            <texturesliderbar colordiffuse="FF00CED1">white.png</texturesliderbar>
            <texturesliderbarfocus colordiffuse="FF00CED1">white.png</texturesliderbarfocus>
        </control>
        
        <!-- Footer / Navigation Hints -->
        <control type="group">
            <posx>40</posx>
            <posy>1020</posy>
            <width>1840</width>
            <height>50</height>
            
            <control type="label">
                <posx>0</posx>
                <posy>10</posy>
                <width>1840</width>
                <height>30</height>
                <label>[COLOR FF808080]← → Navigate Time | ↑ ↓ Change Channel | ENTER Play | BACK Exit[/COLOR]</label>
                <font>font12</font>
                <textcolor>FF808080</textcolor>
                <align>center</align>
            </control>
        </control>
    </controls>
</window>
