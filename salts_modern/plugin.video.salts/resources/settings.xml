<?xml version="1.0" encoding="UTF-8"?>
<settings version="2">
    <section id="general">
        <category id="general" label="General">
            <group id="1" label="General Settings">
                <setting id="auto_play" type="boolean" label="Auto-play first source" default="false"/>
                <setting id="source_timeout" type="integer" label="Source timeout (seconds)" default="30"/>
                <setting id="max_results" type="integer" label="Maximum results per scraper" default="50"/>
            </group>
        </category>
        
        <category id="debrid" label="Debrid Services">
            <group id="1" label="Real-Debrid">
                <setting id="realdebrid_enabled" type="boolean" label="Enable Real-Debrid" default="false"/>
                <setting id="realdebrid_token" type="string" label="Access Token" default="" visible="eq(-1,true)"/>
                <setting id="realdebrid_refresh" type="string" label="Refresh Token" default="" visible="false"/>
                <setting id="realdebrid_expires" type="string" label="Expires" default="0" visible="false"/>
            </group>
            
            <group id="2" label="Premiumize">
                <setting id="premiumize_enabled" type="boolean" label="Enable Premiumize" default="false"/>
                <setting id="premiumize_token" type="string" label="API Key" default="" visible="eq(-1,true)"/>
            </group>
            
            <group id="3" label="AllDebrid">
                <setting id="alldebrid_enabled" type="boolean" label="Enable AllDebrid" default="false"/>
                <setting id="alldebrid_token" type="string" label="API Key" default="" visible="eq(-1,true)"/>
            </group>
        </category>
        
        <category id="scrapers" label="Scrapers">
            <group id="1" label="Torrent Sites">
                <setting id="1337x_enabled" type="boolean" label="1337x" default="true"/>
                <setting id="yts_enabled" type="boolean" label="YTS (Movies only)" default="true"/>
                <setting id="eztv_enabled" type="boolean" label="EZTV (TV only)" default="true"/>
                <setting id="torrentgalaxy_enabled" type="boolean" label="TorrentGalaxy" default="true"/>
                <setting id="thepiratebay_enabled" type="boolean" label="ThePirateBay" default="true"/>
                <setting id="limetorrents_enabled" type="boolean" label="LimeTorrents" default="true"/>
                <setting id="torrentz2_enabled" type="boolean" label="Torrentz2" default="true"/>
                <setting id="rarbg_enabled" type="boolean" label="RARBG (Mirrors)" default="true"/>
                <setting id="nyaa_enabled" type="boolean" label="Nyaa (Anime)" default="true"/>
            </group>
            
            <group id="2" label="Indexer Aggregators">
                <setting id="jackett_enabled" type="boolean" label="Enable Jackett" default="false"/>
                <setting id="jackett_url" type="string" label="Jackett URL" default="http://localhost:9117" visible="eq(-1,true)"/>
                <setting id="jackett_api_key" type="string" label="Jackett API Key" default="" visible="eq(-2,true)"/>
                
                <setting id="prowlarr_enabled" type="boolean" label="Enable Prowlarr" default="false"/>
                <setting id="prowlarr_url" type="string" label="Prowlarr URL" default="http://localhost:9696" visible="eq(-1,true)"/>
                <setting id="prowlarr_api_key" type="string" label="Prowlarr API Key" default="" visible="eq(-2,true)"/>
            </group>
            
            <group id="3" label="APIs">
                <setting id="torrentapi_enabled" type="boolean" label="TorrentAPI" default="false"/>
            </group>
        </category>
        
        <category id="playback" label="Playback">
            <group id="1" label="Quality Filters">
                <setting id="filter_cam" type="boolean" label="Filter CAM/TS quality" default="true"/>
                <setting id="min_quality" type="select" label="Minimum quality" default="0">
                    <option value="0">Any</option>
                    <option value="1">480p</option>
                    <option value="2">720p</option>
                    <option value="3">1080p</option>
                    <option value="4">4K</option>
                </setting>
            </group>
            
            <group id="2" label="Sorting">
                <setting id="sort_by" type="select" label="Sort sources by" default="0">
                    <option value="0">Seeds</option>
                    <option value="1">Quality</option>
                    <option value="2">Size</option>
                </setting>
            </group>
        </category>
        
        <category id="advanced" label="Advanced">
            <group id="1" label="Cache">
                <setting id="cache_duration" type="integer" label="Cache duration (hours)" default="8"/>
                <setting id="clear_cache" type="action" label="Clear cache" action="RunPlugin(plugin://plugin.video.salts/?mode=clear_cache)"/>
            </group>
            
            <group id="2" label="Debug">
                <setting id="debug_enabled" type="boolean" label="Enable debug logging" default="false"/>
            </group>
        </category>
    </section>
</settings>
