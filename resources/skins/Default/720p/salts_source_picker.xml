<?xml version="1.0" encoding="UTF-8"?>
<!--
    SALTS - Fullscreen Source Picker (Salts-style)

    Rendered by salts_lib.sources_window.SaltsSourcePickerWindow.

    Reference resolution: 1280x720

    Control IDs used by Python:
        110  Backdrop image (fanart of current title)
        111  Poster image
        120  Title label
        121  Summary label (counts + qualities)
        200  Sources list
        300  Cancel button
        400  Item counter ("41 items - 1/5")
-->
<window type="dialog" id="13122">
    <defaultcontrol always="true">200</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx><posy>0</posy>
    </coordinates>

    <animation effect="fade" time="200">WindowOpen</animation>
    <animation effect="fade" time="160">WindowClose</animation>

    <controls>
        <!-- ===== Full-screen backdrop ===== -->
        <control type="image" id="110">
            <left>0</left><top>0</top>
            <width>1280</width><height>720</height>
            <texture fallback="../../../../fanart.jpg">../../../../fanart.jpg</texture>
            <aspectratio>scale</aspectratio>
        </control>
        <control type="image">
            <left>0</left><top>0</top><width>1280</width><height>720</height>
            <texture>black-back.png</texture>
            <colordiffuse>D0000000</colordiffuse>
            <aspectratio>stretch</aspectratio>
        </control>

        <!-- Top gold accent -->
        <control type="image">
            <left>0</left><top>0</top><width>1280</width><height>3</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <!-- SALTS brand top-left -->
        <control type="image">
            <left>40</left><top>32</top><width>40</width><height>40</height>
            <texture>../../../../icon.png</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>92</left><top>36</top><width>400</width><height>32</height>
            <font>font13</font>
            <textcolor>FFFFD700</textcolor>
            <label>SALTS</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <!-- ===== Poster ===== -->
        <control type="image" id="111">
            <left>40</left><top>110</top><width>240</width><height>360</height>
            <texture fallback="../../../../icon.png">../../../../icon.png</texture>
            <aspectratio>keep</aspectratio>
            <bordertexture border="2" colordiffuse="FFFFD700">black-back.png</bordertexture>
            <bordersize>2</bordersize>
        </control>

        <!-- Title -->
        <control type="label" id="120">
            <left>40</left><top>484</top><width>240</width><height>34</height>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>Title</label>
            <align>left</align><aligny>center</aligny>
            <wrapmultiline>true</wrapmultiline>
        </control>

        <!-- Summary card under title -->
        <control type="image">
            <left>40</left><top>528</top><width>240</width><height>148</height>
            <texture>black-back.png</texture>
            <colordiffuse>D00d1117</colordiffuse>
        </control>
        <control type="image">
            <left>40</left><top>528</top><width>4</width><height>148</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>
        <control type="label" id="121">
            <left>56</left><top>538</top><width>216</width><height>130</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>Loading...</label>
            <align>left</align><aligny>top</aligny>
            <wrapmultiline>true</wrapmultiline>
        </control>

        <!-- ===== Sources list ===== -->
        <control type="image">
            <left>300</left><top>110</top><width>940</width><height>566</height>
            <texture>black-back.png</texture>
            <colordiffuse>CC0d1117</colordiffuse>
        </control>
        <control type="image">
            <left>300</left><top>110</top><width>940</width><height>2</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <control type="list" id="200">
            <left>308</left><top>120</top><width>924</width><height>546</height>
            <onleft>200</onleft>
            <onright>300</onright>
            <onup>200</onup>
            <ondown>200</ondown>
            <pagecontrol>-</pagecontrol>
            <scrolltime>180</scrolltime>

            <itemlayout height="56" width="924">
                <control type="label">
                    <left>16</left><top>8</top><width>892</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFE6EDF3</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </itemlayout>

            <focusedlayout height="56" width="924">
                <!-- ULTRA-VISIBLE HIGHLIGHT - Bright solid background with massive border -->
                
                <!-- Bright GOLD background - fully opaque, impossible to miss -->
                <control type="image">
                    <left>0</left><top>0</top><width>924</width><height>56</height>
                    <texture>black-back.png</texture>
                    <colordiffuse>FFFFD700</colordiffuse>
                </control>
                
                <!-- EXTRA THICK border for maximum visibility -->
                <control type="image">
                    <left>0</left><top>0</top><width>924</width><height>56</height>
                    <texture>black-back.png</texture>
                    <colordiffuse>00000000</colordiffuse>
                    <bordertexture border="6" colordiffuse="FFFF8C00">black-back.png</bordertexture>
                    <bordersize>6</bordersize>
                </control>
                
                <!-- Selection arrow/indicator on the left -->
                <control type="label">
                    <left>12</left><top>4</top><width>40</width><height>48</height>
                    <font>font13_title</font>
                    <textcolor>FF000000</textcolor>
                    <label>▶</label>
                    <align>center</align><aligny>center</aligny>
                </control>
                
                <!-- Label text - PLAIN VERSION without BBCode, black text on gold background -->
                <control type="label">
                    <left>50</left><top>4</top><width>860</width><height>48</height>
                    <font>font12</font>
                    <textcolor>FF000000</textcolor>
                    <shadowcolor>88FFFFFF</shadowcolor>
                    <label>$INFO[ListItem.Property(plain_label)]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </focusedlayout>
            <content/>
        </control>

        <!-- Item counter -->
        <control type="label" id="400">
            <left>308</left><top>682</top><width>500</width><height>22</height>
            <font>font11</font>
            <textcolor>FF8b949e</textcolor>
            <label></label>
            <align>left</align><aligny>center</aligny>
        </control>

        <!-- Cancel button -->
        <control type="button" id="300">
            <left>1100</left><top>678</top><width>140</width><height>32</height>
            <font>font12</font>
            <textcolor>FF0d1117</textcolor>
            <focusedcolor>FF0d1117</focusedcolor>
            <align>center</align><aligny>center</aligny>
            <label>Cancel</label>
            <texturenofocus colordiffuse="FFFFD700">black-back.png</texturenofocus>
            <texturefocus colordiffuse="FFFFE655">black-back.png</texturefocus>
            <onleft>200</onleft>
            <onright>200</onright>
            <onup>200</onup>
            <ondown>200</ondown>
        </control>
    </controls>
</window>
