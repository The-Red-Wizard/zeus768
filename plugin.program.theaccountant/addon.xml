<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.program.theaccountant" name="The Accountant" version="4.0.3" provider-name="zeus768">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="main.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.service" library="service.py" start="login"/>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">The Accountant: Master Pro Suite</summary>
        <description lang="en">v4.0.1: Device code auth for RD/AD/Trakt. Account cards with full details. Expiry warnings on startup. Syncs to 15+ addons. Speed optimizer, auto-clean, IPTV vault, USB backup, repair tools.</description>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
