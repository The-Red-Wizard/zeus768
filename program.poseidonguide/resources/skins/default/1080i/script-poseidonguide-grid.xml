<?xml version="1.0" encoding="UTF-8"?>
<!--
    Poseidon Guide - Sky/Virgin TIME-RULER GRID view
    Channels stacked vertically, a time axis across the top, and an
    N-hour viewport of programme blocks with a picture-in-picture tile
    in the top-right. Theme colours come from Skin.String(PG_*).

    Kodi gives us limited layout flexibility inside a scrollable list, so
    the "time ruler" grid is implemented as:
      - A fixed header strip drawing 6 time-slot labels
      - A vertically-scrolling list of channel rows; each row contains
        up to 6 programme blocks positioned by the Python side as
        individual labels (so a single ListItem represents one channel
        row, with blocks stored as Properties Block1..Block6Title/Time).
    Navigation up/down moves through channels; left/right pans the time
    window by one slot.
-->
<window type="window" id="6200">
    <defaultcontrol always="true">9000</defaultcontrol>
    <coordinates><system>1</system><posx>0</posx><posy>0</posy></coordinates>
    <controls>
        <!-- Background -->
        <control type="image">
            <posx>0</posx><posy>0</posy>
            <width>1920</width><height>1080</height>
            <texture fallback="black">black.png</texture>
            <colordiffuse>$INFO[Skin.String(PG_BG)]</colordiffuse>
        </control>

        <!-- Header strip -->
        <control type="image">
            <posx>0</posx><posy>0</posy>
            <width>1920</width><height>100</height>
            <texture fallback="black">black.png</texture>
            <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse>
        </control>
        <control type="image">
            <posx>40</posx><posy>20</posy>
            <width>140</width><height>60</height>
            <aspectratio>keep</aspectratio>
            <texture>$INFO[Skin.String(PG_Logo)]</texture>
        </control>
        <control type="label">
            <posx>200</posx><posy>20</posy>
            <width>1000</width><height>60</height>
            <font>font30_title</font>
            <textcolor>$INFO[Skin.String(PG_Label)]</textcolor>
            <label>TV Guide  -  $INFO[Window.Property(window_label)]</label>
            <aligny>center</aligny>
        </control>
        <control type="label">
            <posx>1720</posx><posy>30</posy>
            <width>160</width><height>40</height>
            <align>right</align>
            <font>font30_title</font>
            <textcolor>$INFO[Skin.String(PG_Label)]</textcolor>
            <label>$INFO[System.Time(hh:mm)]</label>
        </control>

        <!-- PiP tile -->
        <control type="group" visible="!Skin.String(PG_PiP_Hidden,true)">
            <control type="image">
                <posx>1440</posx><posy>120</posy>
                <width>440</width><height>258</height>
                <texture fallback="black">black.png</texture>
                <colordiffuse>FF000000</colordiffuse>
            </control>
            <control type="videowindow">
