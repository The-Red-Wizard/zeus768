<?xml version="1.0" encoding="UTF-8"?>
<!--
    Poseidon Guide - Sky-style EPG (LIST view)
    v1.5.0 - List view redesigned to match Sky Q.
      * Deep sky-purple background (matches the sky icon).
      * Sky icon image rendered top-left.
      * Each channel row carries 5 inline EPG time-slot tabs to the
        right of the channel name (the focus pill highlights all 6
        cells together, just like the real Sky guide).
-->
<window type="window" id="6100">
    <defaultcontrol always="true">9000</defaultcontrol>
    <coordinates><system>1</system><posx>0</posx><posy>0</posy></coordinates>
    <controls>
        <!-- Base background: deep sky purple -->
        <control type="image">
            <posx>0</posx><posy>0</posy>
            <width>1920</width><height>1080</height>
            <texture>white.png</texture>
            <colordiffuse>$INFO[Skin.String(PG_BG)]</colordiffuse>
        </control>
        <!-- Lighter band across the middle to fake a vertical gradient -->
        <control type="image">
            <posx>0</posx><posy>320</posy>
            <width>1920</width><height>360</height>
            <texture>white.png</texture>
            <colordiffuse>$INFO[Skin.String(PG_BG2)]</colordiffuse>
        </control>
        <!-- Soft diagonal highlight on the right side of the hero -->
        <control type="image">
            <posx>900</posx><posy>0</posy>
            <width>1020</width><height>440</height>
            <texture>white.png</texture>
            <colordiffuse>22FFFFFF</colordiffuse>
        </control>

        <!-- ============================ HERO HEADER ============================ -->
        <!-- Sky logo image, top-left -->
        <control type="image">
            <posx>40</posx><posy>30</posy>
            <width>140</width><height>80</height>
            <aspectratio>keep</aspectratio>
            <texture>$INFO[Skin.String(PG_SkyLogo)]</texture>
        </control>
        <!-- Clock -->
        <control type="label">
            <posx>1700</posx><posy>40</posy>
            <width>180</width><height>40</height>
            <align>right</align>
            <font>font30_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>$INFO[System.Time(hh:mm)]</label>
        </control>

        <!-- Channel chip (small logo + name like Sky's hero) -->
        <control type="image">
            <posx>60</posx><posy>140</posy>
            <width>120</width><height>70</height>
            <aspectratio>keep</aspectratio>
            <texture>$INFO[Window.Property(hero_logo)]</texture>
        </control>

        <!-- Programme title -->
        <control type="label">
            <posx>60</posx><posy>225</posy>
            <width>900</width><height>56</height>
            <font>font45</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>[B]$INFO[Window.Property(selected_title)][/B]</label>
            <aligny>center</aligny>
        </control>
        <!-- Meta line -->
        <control type="label">
            <posx>60</posx><posy>290</posy>
            <width>900</width><height>30</height>
            <font>font13</font>
            <textcolor>FFC9CCF2</textcolor>
            <label>$INFO[Window.Property(selected_meta)]</label>
        </control>
        <!-- Synopsis -->
        <control type="textbox">
            <posx>60</posx><posy>325</posy>
            <width>900</width><height>80</height>
            <font>font13</font>
            <textcolor>FFE5E7FA</textcolor>
            <label>$INFO[Window.Property(selected_desc)]</label>
        </control>

        <!-- ============================ PICTURE-IN-PICTURE ===================== -->
        <control type="group" visible="!Skin.String(PG_PiP_Hidden,true)">
            <control type="image">
                <posx>1016</posx><posy>36</posy>
                <width>508</width><height>290</height>
                <texture>white.png</texture>
                <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse>
                <visible>!IsEmpty(Window.Property(pip_channel))</visible>
            </control>
            <control type="image">
                <posx>1020</posx><posy>40</posy>
                <width>500</width><height>282</height>
                <texture>white.png</texture>
                <colordiffuse>FF000000</colordiffuse>
            </control>
            <control type="videowindow">
                <posx>1024</posx><posy>44</posy>
                <width>492</width><height>274</height>
            </control>
            <control type="label">
                <posx>1020</posx><posy>328</posy>
                <width>500</width><height>26</height>
                <font>font12</font>
                <align>center</align>
                <textcolor>FFC9CCF2</textcolor>
                <label>Now Previewing:  [B]$INFO[Window.Property(pip_channel)][/B]</label>
            </control>
        </control>

        <!-- ============================ TIME RULER ============================ -->
        <control type="image">
            <posx>40</posx><posy>460</posy>
            <width>320</width><height>50</height>
            <texture>white.png</texture>
            <colordiffuse>30FFFFFF</colordiffuse>
        </control>
        <control type="label">
            <posx>60</posx><posy>460</posy>
            <width>280</width><height>50</height>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>[B]Today[/B]</label>
            <aligny>center</aligny>
        </control>
        <control type="label"><posx>360</posx><posy>460</posy><width>304</width><height>50</height>
            <font>font13_title</font><textcolor>FFE5E7FA</textcolor>
            <align>left</align><aligny>center</aligny>
            <label>[B]$INFO[Window.Property(slot1)][/B]</label></control>
        <control type="label"><posx>664</posx><posy>460</posy><width>304</width><height>50</height>
            <font>font13_title</font><textcolor>FFE5E7FA</textcolor>
            <align>left</align><aligny>center</aligny>
            <label>[B]$INFO[Window.Property(slot2)][/B]</label></control>
        <control type="label"><posx>968</posx><posy>460</posy><width>304</width><height>50</height>
            <font>font13_title</font><textcolor>FFE5E7FA</textcolor>
            <align>left</align><aligny>center</aligny>
            <label>[B]$INFO[Window.Property(slot3)][/B]</label></control>
        <control type="label"><posx>1272</posx><posy>460</posy><width>304</width><height>50</height>
            <font>font13_title</font><textcolor>FFE5E7FA</textcolor>
            <align>left</align><aligny>center</aligny>
            <label>[B]$INFO[Window.Property(slot4)][/B]</label></control>
        <control type="label"><posx>1576</posx><posy>460</posy><width>304</width><height>50</height>
            <font>font13_title</font><textcolor>FFE5E7FA</textcolor>
            <align>left</align><aligny>center</aligny>
            <label>[B]$INFO[Window.Property(slot5)][/B]</label></control>

        <!-- "Now" indicator line -->
        <control type="image" visible="!IsEmpty(Window.Property(now_x))">
            <posx>$INFO[Window.Property(now_x)]</posx>
            <posy>510</posy>
            <width>2</width><height>520</height>
            <texture>white.png</texture>
            <colordiffuse>FFFFFFFF</colordiffuse>
        </control>

        <!-- ============================ CHANNEL ROWS LIST ===================== -->
        <control type="list" id="9000">
            <posx>40</posx><posy>520</posy>
            <width>1840</width><height>510</height>
            <onleft>9000</onleft>
            <onright>9000</onright>
            <onup>9100</onup>
            <ondown>9100</ondown>
            <scrolltime>120</scrolltime>

            <itemlayout height="65" width="1840">
                <!-- Channel cell -->
                <control type="image">
                    <posx>0</posx><posy>2</posy><width>320</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>30FFFFFF</colordiffuse>
                </control>
                <control type="image">
                    <posx>10</posx><posy>8</posy><width>50</width><height>50</height>
                    <aspectratio>keep</aspectratio>
                    <texture>$INFO[ListItem.Icon]</texture>
                </control>
                <control type="label">
                    <posx>70</posx><posy>2</posy><width>180</width><height>61</height>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Label]</label>
                </control>
                <control type="label">
                    <posx>250</posx><posy>2</posy><width>60</width><height>61</height>
                    <font>font13</font>
                    <textcolor>FFC9CCF2</textcolor>
                    <align>right</align><aligny>center</aligny>
                    <label>$INFO[ListItem.Property(num)]</label>
                </control>
                <!-- 5 EPG tabs -->
                <control type="image"><posx>320</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture><colordiffuse>20FFFFFF</colordiffuse></control>
                <control type="label"><posx>332</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Property(b1t)]</label></control>

                <control type="image"><posx>624</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture><colordiffuse>20FFFFFF</colordiffuse></control>
                <control type="label"><posx>636</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Property(b2t)]</label></control>

                <control type="image"><posx>928</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture><colordiffuse>20FFFFFF</colordiffuse></control>
                <control type="label"><posx>940</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Property(b3t)]</label></control>

                <control type="image"><posx>1232</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture><colordiffuse>20FFFFFF</colordiffuse></control>
                <control type="label"><posx>1244</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Property(b4t)]</label></control>

                <control type="image"><posx>1536</posx><posy>2</posy><width>304</width><height>61</height>
                    <texture>white.png</texture><colordiffuse>20FFFFFF</colordiffuse></control>
                <control type="label"><posx>1548</posx><posy>2</posy><width>286</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>$INFO[ListItem.Property(b5t)]</label></control>
            </itemlayout>

            <focusedlayout height="65" width="1840">
                <!-- Channel cell highlighted -->
                <control type="image">
                    <posx>0</posx><posy>2</posy><width>320</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse>
                </control>
                <control type="image">
                    <posx>10</posx><posy>8</posy><width>50</width><height>50</height>
                    <aspectratio>keep</aspectratio>
                    <texture>$INFO[ListItem.Icon]</texture>
                </control>
                <control type="label">
                    <posx>70</posx><posy>2</posy><width>180</width><height>61</height>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Label][/B]</label>
                </control>
                <control type="label">
                    <posx>250</posx><posy>2</posy><width>60</width><height>61</height>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>right</align><aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(num)][/B]</label>
                </control>
                <!-- 5 EPG tabs highlighted -->
                <control type="image"><posx>320</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse></control>
                <control type="label"><posx>332</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(b1t)][/B]</label></control>

                <control type="image"><posx>624</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse></control>
                <control type="label"><posx>636</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(b2t)][/B]</label></control>

                <control type="image"><posx>928</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse></control>
                <control type="label"><posx>940</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(b3t)][/B]</label></control>

                <control type="image"><posx>1232</posx><posy>2</posy><width>302</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse></control>
                <control type="label"><posx>1244</posx><posy>2</posy><width>284</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(b4t)][/B]</label></control>

                <control type="image"><posx>1536</posx><posy>2</posy><width>304</width><height>61</height>
                    <texture>white.png</texture>
                    <colordiffuse>$INFO[Skin.String(PG_Accent)]</colordiffuse></control>
                <control type="label"><posx>1548</posx><posy>2</posy><width>286</width><height>61</height>
                    <font>font13</font><textcolor>FFFFFFFF</textcolor>
                    <aligny>center</aligny>
                    <label>[B]$INFO[ListItem.Property(b5t)][/B]</label></control>
            </focusedlayout>
        </control>

        <!-- Footer hint -->
        <control type="label">
            <posx>40</posx><posy>1045</posy>
            <width>1840</width><height>28</height>
            <font>font10</font>
            <align>center</align>
            <textcolor>FFC9CCF2</textcolor>
            <label>OK once: preview in PiP   |   OK twice: full screen   |   left/right: pan time   |   up/down: channel   |   I: grid view   |   C: pin to favourites</label>
        </control>
        <!-- FAVOURITES button (v1.7.2) - focusable, D-pad reachable
             via onup/ondown on the channel list.  Label flips between
             "FAVOURITES (N)" and "ALL CHANNELS" so the same button
             toggles the view. -->
        <control type="button" id="9100">
            <posx>1580</posx><posy>990</posy>
            <width>300</width><height>44</height>
            <label>[B]$INFO[Window(Home).Property(pg_fav_label)][/B]</label>
            <font>font13_title</font>
            <textcolor>FFFFFFFF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <align>center</align><aligny>center</aligny>
            <texturefocus colordiffuse="$INFO[Skin.String(PG_Accent)]" border="2">white.png</texturefocus>
            <texturenofocus colordiffuse="AA1E2530" border="2">white.png</texturenofocus>
            <onleft>9000</onleft>
            <onright>9100</onright>
            <onup>9000</onup>
            <ondown>9000</ondown>
        </control>
    </controls>
</window>
