<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="program.poseidonguide" name="Poseidon Guide" version="1.3.1" provider-name="poseidon12">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
        <import addon="script.module.requests" version="2.25.1"/>
        <import addon="plugin.video.poseidonplayer" version="2.2.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en">EPG Grid Guide for Poseidon Player</summary>
        <description lang="en">Poseidon Guide - Full EPG grid view for Poseidon Player with solid dark background, channel numbers, icons and names.</description>
        <platform>all</platform>
        <license>GPL-3.0-only</license>
        <news>v1.0.3 - Fixed channel column layout, removed transparency, improved EPG grid</news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>