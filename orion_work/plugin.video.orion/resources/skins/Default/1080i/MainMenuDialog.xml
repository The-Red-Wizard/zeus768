        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Backdrop image -->
        <control type="image" id="9999">
            <left>200</left>
            <top>0</top>
            <width>1720</width>
            <height>450</height>
            <aspectratio>scale</aspectratio>
            <texture>$INFO[Window.Property(backdrop)]</texture>
            <colordiffuse>60FFFFFF</colordiffuse>
        </control>
        
        <!-- Backdrop gradient -->
        <control type="image">
            <left>200</left>
