<?xml version="1.0" encoding="UTF-8"?>
<!-- Orion v3.5.0 - Netflix-style Main Menu with BIGGER Thumbnails -->
<!-- Color Theme: Deep dark (#0D0D15), Cyan accent (#00D4FF), Purple focus (#6366F1) -->
<window type="dialog">
    <defaultcontrol always="true">100</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Main background - deep dark gradient -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Backdrop image (dynamic) -->
        <control type="image" id="9999">
            <left>200</left>
            <top>0</top>
            <width>1720</width>
            <height>500</height>
            <aspectratio>scale</aspectratio>
            <texture fallback="fanart.jpg">$INFO[Window.Property(backdrop)]</texture>
            <colordiffuse>80FFFFFF</colordiffuse>
        </control>
        
        <!-- Backdrop gradient overlay -->
        <control type="image">
            <left>200</left>
            <top>350</top>
            <width>1720</width>
            <height>200</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Left sidebar background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>200</width>
            <height>1080</height>
            <texture colordiffuse="F0080810">white.png</texture>
        </control>
        
        <!-- Sidebar right border -->
        <control type="image">
            <left>198</left>
            <top>0</top>
            <width>2</width>
            <height>1080</height>
            <texture colordiffuse="40404060">white.png</texture>
        </control>
        
        <!-- Orion Icon in sidebar -->
        <control type="image" id="1">
            <left>60</left>
            <top>30</top>
            <width>80</width>
            <height>80</height>
            <aspectratio>keep</aspectratio>
            <texture fallback="icon.png">icon.png</texture>
        </control>
        
        <!-- ORION text under icon -->
        <control type="label">
            <left>0</left>
            <top>115</top>
            <width>200</width>
            <height>30</height>
            <label>ORION</label>
            <font>font12</font>
            <textcolor>FF00D4FF</textcolor>
            <align>center</align>
        </control>
        
        <!-- Sidebar navigation menu -->
        <control type="list" id="100">
            <left>0</left>
            <top>170</top>
            <width>200</width>
            <height>700</height>
            <onup>100</onup>
            <ondown>100</ondown>
            <onleft>100</onleft>
            <onright>200</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="200" height="60">
                <control type="image">
                    <left>20</left>
                    <top>15</top>
                    <width>28</width>
                    <height>28</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="FF808090">$INFO[ListItem.Property(icon_path)]</texture>
                </control>
                <control type="label">
                    <left>58</left>
                    <top>15</top>
                    <width>130</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font12</font>
                    <textcolor>FFB0B0C0</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="200" height="60">
                <control type="image">
                    <left>0</left>
                    <top>5</top>
                    <width>200</width>
                    <height>50</height>
                    <texture colordiffuse="40303060">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left>
                    <top>5</top>
                    <width>4</width>
                    <height>50</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <control type="image">
                    <left>20</left>
                    <top>15</top>
                    <width>28</width>
                    <height>28</height>
                    <aspectratio>keep</aspectratio>
                    <texture colordiffuse="FF00D4FF">$INFO[ListItem.Property(icon_path)]</texture>
                </control>
                <control type="label">
                    <left>58</left>
                    <top>15</top>
                    <width>130</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Settings button at bottom of sidebar -->
        <control type="button" id="101">
            <left>10</left>
            <top>920</top>
            <width>180</width>
            <height>50</height>
            <label>Settings</label>
            <font>font12</font>
            <textcolor>FF808090</textcolor>
            <focusedcolor>FF00D4FF</focusedcolor>
            <texturefocus colordiffuse="40303060">white.png</texturefocus>
            <texturenofocus colordiffuse="00000000">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>100</onup>
            <ondown>100</ondown>
            <onright>200</onright>
        </control>
        
        <!-- Hero section - Continue Watching / Featured -->
        <control type="group" id="150">
            <left>230</left>
            <top>80</top>
            <width>800</width>
            <height>350</height>
            
            <control type="label" id="151">
                <left>0</left>
                <top>0</top>
                <width>400</width>
                <height>30</height>
                <label>$INFO[Window.Property(hero_title)]</label>
                <font>font10</font>
                <textcolor>FF808090</textcolor>
            </control>
            
            <control type="label" id="152">
                <left>0</left>
                <top>40</top>
                <width>600</width>
                <height>50</height>
                <label>$INFO[Window.Property(hero_main)]</label>
                <font>font_MainMenu</font>
                <textcolor>FFFFFFFF</textcolor>
            </control>
            
            <control type="label" id="153">
                <left>0</left>
                <top>100</top>
                <width>400</width>
                <height>30</height>
                <label>$INFO[Window.Property(hero_subtitle)]</label>
                <font>font12</font>
                <textcolor>FFB0B0C0</textcolor>
            </control>
            
            <control type="button" id="154">
                <left>0</left>
                <top>150</top>
                <width>120</width>
                <height>45</height>
                <label>PLAY</label>
                <font>font12</font>
                <textcolor>FF101020</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="FFE0E0E0">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>200</onup>
                <ondown>200</ondown>
                <onleft>100</onleft>
                <onright>200</onright>
            </control>
            
            <control type="label" id="155">
                <left>250</left>
                <top>280</top>
                <width>550</width>
                <height>40</height>
                <label>$INFO[Window.Property(featured_title)]</label>
                <font>font14</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>right</align>
            </control>
        </control>
        
        <!-- Content rows section -->
        <control type="group" id="300">
            <left>230</left>
            <top>420</top>
            <width>1650</width>
            <height>650</height>
            
            <!-- Row 1 title -->
            <control type="label" id="301">
                <left>0</left>
                <top>0</top>
                <width>400</width>
                <height>35</height>
                <label>$INFO[Window.Property(row1_title)]</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
            </control>
            
            <!-- Row 1 content - BIGGER POSTERS: 204x284px (was 130x195px) -->
            <control type="list" id="200">
                <left>0</left>
                <top>40</top>
                <width>1650</width>
                <height>310</height>
                <orientation>horizontal</orientation>
                <onup>154</onup>
                <ondown>210</ondown>
                <onleft>100</onleft>
                <onright>200</onright>
                <scrolltime>200</scrolltime>
                <itemlayout width="220" height="300">
                    <!-- Poster background -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <texture colordiffuse="40202040">white.png</texture>
                    </control>
                    <!-- Poster - BIGGER: 204x284px -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <aspectratio>scale</aspectratio>
                        <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <!-- Rating badge -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <texture colordiffuse="E0101020">white.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                    <control type="label">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <label>★ $INFO[ListItem.Property(rating)]</label>
                        <font>font10</font>
                        <textcolor>FFFFCC00</textcolor>
                        <align>center</align>
                        <aligny>center</aligny>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                </itemlayout>
                <focusedlayout width="220" height="300">
                    <!-- Focus glow - Cyan accent -->
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>220</width>
                        <height>300</height>
                        <texture colordiffuse="FF00D4FF">white.png</texture>
                    </control>
                    <!-- Poster - BIGGER: 204x284px -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <aspectratio>scale</aspectratio>
                        <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <!-- Rating badge -->
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <texture colordiffuse="E0101020">white.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                    <control type="label">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <label>★ $INFO[ListItem.Property(rating)]</label>
                        <font>font10</font>
                        <textcolor>FFFFCC00</textcolor>
                        <align>center</align>
                        <aligny>center</aligny>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                </focusedlayout>
            </control>
            
            <!-- Row 2 title -->
            <control type="label" id="311">
                <left>0</left>
                <top>360</top>
                <width>400</width>
                <height>35</height>
                <label>$INFO[Window.Property(row2_title)]</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
            </control>
            
            <!-- Row 2 content - BIGGER POSTERS -->
            <control type="list" id="210">
                <left>0</left>
                <top>400</top>
                <width>1650</width>
                <height>310</height>
                <orientation>horizontal</orientation>
                <onup>200</onup>
                <ondown>210</ondown>
                <onleft>100</onleft>
                <onright>210</onright>
                <scrolltime>200</scrolltime>
                <itemlayout width="220" height="300">
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <texture colordiffuse="40202040">white.png</texture>
                    </control>
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <aspectratio>scale</aspectratio>
                        <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <texture colordiffuse="E0101020">white.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                    <control type="label">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <label>★ $INFO[ListItem.Property(rating)]</label>
                        <font>font10</font>
                        <textcolor>FFFFCC00</textcolor>
                        <align>center</align>
                        <aligny>center</aligny>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                </itemlayout>
                <focusedlayout width="220" height="300">
                    <control type="image">
                        <left>0</left>
                        <top>0</top>
                        <width>220</width>
                        <height>300</height>
                        <texture colordiffuse="FF00D4FF">white.png</texture>
                    </control>
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>204</width>
                        <height>284</height>
                        <aspectratio>scale</aspectratio>
                        <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                    </control>
                    <control type="image">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <texture colordiffuse="E0101020">white.png</texture>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                    <control type="label">
                        <left>8</left>
                        <top>8</top>
                        <width>50</width>
                        <height>26</height>
                        <label>★ $INFO[ListItem.Property(rating)]</label>
                        <font>font10</font>
                        <textcolor>FFFFCC00</textcolor>
                        <align>center</align>
                        <aligny>center</aligny>
                        <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                    </control>
                </focusedlayout>
            </control>
        </control>
        
        <!-- Time display -->
        <control type="label">
            <left>1750</left>
            <top>30</top>
            <width>150</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
        </control>
    </controls>
</window>
