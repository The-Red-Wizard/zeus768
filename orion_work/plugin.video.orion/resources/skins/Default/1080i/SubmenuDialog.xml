<?xml version="1.0" encoding="UTF-8"?>
<!-- Orion v3.5.3 - Netflix-style Submenu - FIXED CONTROLS -->
<window type="dialog">
    <defaultcontrol always="true">200</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Main background -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Hero backdrop -->
        <control type="image" id="9000">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>550</height>
            <aspectratio>scale</aspectratio>
            <texture>$INFO[Window.Property(hero_backdrop)]</texture>
            <colordiffuse>50FFFFFF</colordiffuse>
        </control>
        
        <!-- Backdrop gradient left -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>700</width>
            <height>550</height>
            <texture colordiffuse="E00D0D15">white.png</texture>
        </control>
        
        <!-- Backdrop gradient bottom -->
        <control type="image">
            <left>0</left>
            <top>400</top>
            <width>1920</width>
            <height>200</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Cyan accent line -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>3</height>
            <texture colordiffuse="FF00D4FF">white.png</texture>
        </control>
        
        <!-- Back button - ID 50 -->
        <control type="button" id="50">
            <left>40</left>
            <top>20</top>
            <width>80</width>
            <height>40</height>
            <label>BACK</label>
            <font>font12</font>
            <textcolor>FF808080</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="00000000">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <ondown>110</ondown>
            <onright>110</onright>
        </control>
        
        <!-- Page Title - ID 100 -->
        <control type="label" id="100">
            <left>140</left>
            <top>25</top>
            <width>600</width>
            <height>40</height>
            <label>$INFO[Window.Property(page_title)]</label>
            <font>font_MainMenu</font>
            <textcolor>FFFFFFFF</textcolor>
        </control>
        
        <!-- Page Subtitle - ID 101 -->
        <control type="label" id="101">
            <left>140</left>
            <top>70</top>
            <width>600</width>
            <height>25</height>
            <label>$INFO[Window.Property(page_subtitle)]</label>
            <font>font12</font>
            <textcolor>FF909090</textcolor>
        </control>
        
        <!-- Hero Info -->
        <control type="group" id="150">
            <left>60</left>
            <top>120</top>
            <width>600</width>
            <height>300</height>
            
            <!-- Selected Title - ID 151 -->
            <control type="label" id="151">
                <left>0</left>
                <top>0</top>
                <width>600</width>
                <height>50</height>
                <label>$INFO[Window.Property(selected_title)]</label>
                <font>font35_title</font>
                <textcolor>FFFFFFFF</textcolor>
            </control>
            
            <!-- Selected Meta - ID 152 -->
            <control type="label" id="152">
                <left>0</left>
                <top>55</top>
                <width>600</width>
                <height>25</height>
                <label>$INFO[Window.Property(selected_meta)]</label>
                <font>font12</font>
                <textcolor>FF00D4FF</textcolor>
            </control>
            
            <!-- Selected Plot - ID 153 -->
            <control type="textbox" id="153">
                <left>0</left>
                <top>90</top>
                <width>580</width>
                <height>100</height>
                <label>$INFO[Window.Property(selected_plot)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
            </control>
            
            <!-- Watch Now Button - ID 160 -->
            <control type="button" id="160">
                <left>0</left>
                <top>200</top>
                <width>150</width>
                <height>45</height>
                <label>WATCH NOW</label>
                <font>font12</font>
                <textcolor>FF000000</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="FF00D4FF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>200</onup>
                <ondown>200</ondown>
                <onleft>160</onleft>
                <onright>161</onright>
            </control>
            
            <!-- Info Button - ID 161 -->
            <control type="button" id="161">
                <left>170</left>
                <top>200</top>
                <width>100</width>
                <height>45</height>
                <label>INFO</label>
                <font>font12</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>200</onup>
                <ondown>200</ondown>
                <onleft>160</onleft>
                <onright>200</onright>
            </control>
        </control>
        
        <!-- Category Tabs - ID 110 -->
        <control type="list" id="110">
            <left>60</left>
            <top>430</top>
            <width>1800</width>
            <height>55</height>
            <orientation>horizontal</orientation>
            <onup>160</onup>
            <ondown>200</ondown>
            <onleft>110</onleft>
            <onright>110</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="180" height="50">
                <!-- Tab background -->
                <control type="image">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>40</height>
                    <texture colordiffuse="20FFFFFF">white.png</texture>
                </control>
                <control type="label">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FFB0B0B0</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="180" height="50">
                <!-- Tab focused background -->
                <control type="image">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>40</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <control type="label">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FF000000</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Row 1 Title - ID 201 -->
        <control type="label" id="201">
            <left>60</left>
            <top>490</top>
            <width>400</width>
            <height>30</height>
            <label>$INFO[Window.Property(row1_title)]</label>
            <font>font13</font>
            <textcolor>FFFFFFFF</textcolor>
        </control>
        
        <!-- Row 1 Content - ID 200 -->
        <control type="list" id="200">
            <left>60</left>
            <top>525</top>
            <width>1800</width>
            <height>340</height>
            <orientation>horizontal</orientation>
            <onup>110</onup>
            <ondown>300</ondown>
            <onleft>200</onleft>
            <onright>200</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="260" height="330">
                <control type="image">
                    <left>10</left>
                    <top>5</top>
                    <width>240</width>
                    <height>320</height>
                    <texture colordiffuse="25FFFFFF">white.png</texture>
                </control>
                <control type="image">
                    <left>10</left>
                    <top>5</top>
                    <width>240</width>
                    <height>320</height>
                    <aspectratio>scale</aspectratio>
                    <texture>$INFO[ListItem.Art(poster)]</texture>
                </control>
            </itemlayout>
            <focusedlayout width="260" height="330">
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>260</width>
                    <height>330</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <control type="image">
                    <left>10</left>
                    <top>5</top>
                    <width>240</width>
                    <height>320</height>
                    <aspectratio>scale</aspectratio>
                    <texture>$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Title overlay on focus -->
                <control type="image">
                    <left>10</left>
                    <top>270</top>
                    <width>240</width>
                    <height>55</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                </control>
                <control type="label">
                    <left>15</left>
                    <top>278</top>
                    <width>230</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font11</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Row 2 Content - ID 300 (required by Python) -->
        <control type="list" id="300">
            <left>60</left>
            <top>880</top>
            <width>1800</width>
            <height>200</height>
            <orientation>horizontal</orientation>
            <visible>false</visible>
            <onup>200</onup>
            <ondown>200</ondown>
            <onleft>300</onleft>
            <onright>300</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="260" height="190">
                <control type="image">
                    <left>10</left>
                    <top>5</top>
                    <width>240</width>
                    <height>180</height>
                    <texture>$INFO[ListItem.Art(poster)]</texture>
                </control>
            </itemlayout>
            <focusedlayout width="260" height="190">
                <control type="image">
                    <left>10</left>
                    <top>5</top>
                    <width>240</width>
                    <height>180</height>
                    <texture>$INFO[ListItem.Art(poster)]</texture>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Time display -->
        <control type="label">
            <left>1750</left>
            <top>25</top>
            <width>150</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
        </control>
        
        <!-- Page indicator - ID 250 -->
        <control type="label" id="250">
            <left>1700</left>
            <top>1040</top>
            <width>200</width>
            <height>25</height>
            <label>$INFO[Window.Property(page_info)]</label>
            <font>font10</font>
            <textcolor>FF808080</textcolor>
