<?xml version="1.0" encoding="UTF-8"?>
<!-- Movie/TV Show Detail Dialog with Trailer and Play buttons -->
<window type="dialog">
    <defaultcontrol always="true">800</defaultcontrol>
    <zorder>2</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Semi-transparent backdrop overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="E0000000">white.png</texture>
        </control>
        
        <!-- Detail card container - centered -->
        <control type="group" id="799">
            <left>260</left>
            <top>90</top>
            <width>1400</width>
            <height>900</height>
            
            <!-- Card background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1400</width>
                <height>900</height>
                <texture colordiffuse="FF0D0D15">white.png</texture>
            </control>
            
            <!-- Netflix red accent at top -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1400</width>
                <height>4</height>
                <texture colordiffuse="FFE50914">white.png</texture>
            </control>
            
            <!-- Backdrop image (top area) -->
            <control type="image" id="9100">
                <left>0</left>
                <top>4</top>
                <width>1400</width>
                <height>500</height>
                <aspectratio>scale</aspectratio>
                <texture fallback="fanart.jpg">$INFO[Window.Property(detail_backdrop)]</texture>
                <colordiffuse>80FFFFFF</colordiffuse>
            </control>
            
            <!-- Backdrop gradient overlay -->
            <control type="image">
                <left>0</left>
                <top>300</top>
                <width>1400</width>
                <height>250</height>
                <texture colordiffuse="FF0D0D15">white.png</texture>
            </control>
            
            <!-- Left gradient for text readability -->
            <control type="image">
                <left>0</left>
                <top>4</top>
                <width>600</width>
                <height>500</height>
                <texture colordiffuse="C00D0D15">white.png</texture>
            </control>
            
            <!-- Poster image (left side) -->
            <control type="image" id="9101">
                <left>50</left>
                <top>80</top>
                <width>280</width>
                <height>420</height>
                <aspectratio>scale</aspectratio>
                <texture fallback="icon.png">$INFO[Window.Property(detail_poster)]</texture>
            </control>
            
            <!-- Poster border -->
            <control type="image">
                <left>46</left>
                <top>76</top>
                <width>288</width>
                <height>428</height>
                <texture colordiffuse="40FFFFFF" border="4">white.png</texture>
            </control>
            
            <!-- Close button (X) -->
            <control type="button" id="810">
                <left>1320</left>
                <top>20</top>
                <width>50</width>
                <height>50</height>
                <label>✕</label>
                <font>font16</font>
                <textcolor>FF808080</textcolor>
                <focusedcolor>FFFFFFFF</focusedcolor>
                <texturefocus colordiffuse="80E50914">white.png</texturefocus>
                <texturenofocus colordiffuse="40000000">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <ondown>800</ondown>
                <onleft>810</onleft>
            </control>
            
            <!-- Title -->
            <control type="label" id="820">
                <left>370</left>
                <top>100</top>
                <width>950</width>
                <height>70</height>
                <label>$INFO[Window.Property(detail_title)]</label>
                <font>font45</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
            </control>
            
            <!-- Year • Rating • Runtime • Genres -->
            <control type="label" id="821">
                <left>370</left>
                <top>175</top>
                <width>950</width>
                <height>30</height>
                <label>$INFO[Window.Property(detail_meta)]</label>
                <font>font13</font>
                <textcolor>FF00D4FF</textcolor>
            </control>
            
            <!-- Tagline (if available) -->
            <control type="label" id="822">
                <left>370</left>
                <top>215</top>
                <width>950</width>
                <height>30</height>
                <label>$INFO[Window.Property(detail_tagline)]</label>
                <font>font12_italic</font>
                <textcolor>FFAAAAAA</textcolor>
                <visible>!String.IsEmpty(Window.Property(detail_tagline))</visible>
            </control>
            
            <!-- Plot/Overview -->
            <control type="textbox" id="823">
                <left>370</left>
                <top>260</top>
                <width>980</width>
                <height>200</height>
                <label>$INFO[Window.Property(detail_plot)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
            </control>
            
            <!-- ======================= -->
            <!-- ACTION BUTTONS -->
            <!-- ======================= -->
            
            <!-- Play / Search Sources Button -->
            <control type="button" id="800">
                <left>50</left>
                <top>530</top>
                <width>280</width>
                <height>60</height>
                <label>PLAY</label>
                <font>font14</font>
                <textcolor>FF000000</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="FFE50914">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>810</onup>
                <ondown>801</ondown>
                <onleft>800</onleft>
                <onright>800</onright>
            </control>
            
            <!-- Trailer Button -->
            <control type="button" id="801">
                <left>50</left>
                <top>610</top>
                <width>280</width>
                <height>55</height>
                <label>🎬  TRAILER</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>800</onup>
                <ondown>802</ondown>
                <onleft>801</onleft>
                <onright>801</onright>
            </control>
            
            <!-- Add to Favorites Button -->
            <control type="button" id="802">
                <left>50</left>
                <top>680</top>
                <width>280</width>
                <height>55</height>
                <label>♥  FAVORITE</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>801</onup>
                <ondown>802</ondown>
                <onleft>802</onleft>
                <onright>802</onright>
            </control>
            
            <!-- ======================= -->
            <!-- ADDITIONAL INFO SECTION -->
            <!-- ======================= -->
            
            <!-- Info section background -->
            <control type="image">
                <left>370</left>
                <top>520</top>
                <width>980</width>
                <height>350</height>
                <texture colordiffuse="20FFFFFF">white.png</texture>
            </control>
            
            <!-- Cast label -->
            <control type="label">
                <left>390</left>
                <top>540</top>
                <width>100</width>
                <height>25</height>
                <label>Cast:</label>
                <font>font12</font>
                <textcolor>FF808080</textcolor>
            </control>
            
            <!-- Cast names -->
            <control type="label" id="830">
                <left>500</left>
                <top>540</top>
                <width>830</width>
                <height>25</height>
                <label>$INFO[Window.Property(detail_cast)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
            </control>
            
            <!-- Director label -->
            <control type="label">
                <left>390</left>
                <top>575</top>
                <width>100</width>
                <height>25</height>
                <label>Director:</label>
                <font>font12</font>
                <textcolor>FF808080</textcolor>
            </control>
            
            <!-- Director name -->
            <control type="label" id="831">
                <left>500</left>
                <top>575</top>
                <width>830</width>
                <height>25</height>
                <label>$INFO[Window.Property(detail_director)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
            </control>
            
            <!-- Status (for TV shows) -->
            <control type="label">
                <left>390</left>
                <top>610</top>
                <width>100</width>
                <height>25</height>
                <label>Status:</label>
                <font>font12</font>
                <textcolor>FF808080</textcolor>
                <visible>!String.IsEmpty(Window.Property(detail_status))</visible>
            </control>
            
            <control type="label" id="832">
                <left>500</left>
                <top>610</top>
                <width>400</width>
                <height>25</height>
                <label>$INFO[Window.Property(detail_status)]</label>
                <font>font12</font>
                <textcolor>FF00D4FF</textcolor>
                <visible>!String.IsEmpty(Window.Property(detail_status))</visible>
            </control>
            
            <!-- Seasons info (for TV shows) -->
            <control type="label">
                <left>700</left>
                <top>610</top>
                <width>100</width>
                <height>25</height>
                <label>Seasons:</label>
                <font>font12</font>
                <textcolor>FF808080</textcolor>
                <visible>!String.IsEmpty(Window.Property(detail_seasons))</visible>
            </control>
            
            <control type="label" id="833">
                <left>810</left>
                <top>610</top>
                <width>200</width>
                <height>25</height>
                <label>$INFO[Window.Property(detail_seasons)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
                <visible>!String.IsEmpty(Window.Property(detail_seasons))</visible>
            </control>
            
            <!-- TMDB Rating display -->
            <control type="group">
                <left>390</left>
                <top>660</top>
                <width>300</width>
                <height>60</height>
                
                <!-- Rating background -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>120</width>
                    <height>50</height>
                    <texture colordiffuse="30FFFFFF">white.png</texture>
                </control>
                
                <!-- Star icon -->
                <control type="label">
                    <left>10</left>
                    <top>0</top>
                    <width>30</width>
                    <height>50</height>
                    <label></label>
                    <font>font16</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                
                <!-- Rating value -->
                <control type="label" id="840">
                    <left>40</left>
                    <top>0</top>
                    <width>70</width>
                    <height>50</height>
                    <label>$INFO[Window.Property(detail_rating)]</label>
                    <font>font18</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                
                <!-- Vote count -->
                <control type="label" id="841">
                    <left>130</left>
                    <top>10</top>
                    <width>150</width>
                    <height>30</height>
                    <label>$INFO[Window.Property(detail_votes)] votes</label>
                    <font>font10</font>
                    <textcolor>FF808080</textcolor>
                    <aligny>center</aligny>
                </control>
            </control>
            
            <!-- Media type badge -->
            <control type="image">
                <left>50</left>
                <top>760</top>
                <width>120</width>
                <height>35</height>
                <texture colordiffuse="40E50914">white.png</texture>
            </control>
            <control type="label" id="850">
                <left>50</left>
                <top>760</top>
                <width>120</width>
                <height>35</height>
                <label>$INFO[Window.Property(detail_type)]</label>
                <font>font12</font>
                <textcolor>FFFFFFFF</textcolor>
                <align>center</align>
                <aligny>center</aligny>
            </control>
            
            <!-- TMDB ID (for debugging/reference) -->
            <control type="label">
                <left>50</left>
                <top>810</top>
                <width>280</width>
                <height>25</height>
                <label>TMDB ID: $INFO[Window.Property(detail_tmdb_id)]</label>
                <font>font10</font>
                <textcolor>FF505050</textcolor>
                <align>center</align>
            </control>
        </control>
    </controls>
</window>
