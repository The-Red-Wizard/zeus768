<?xml version="1.0" encoding="UTF-8"?>
<!-- Netflix-style Full Grid View with Page Navigation -->
<window type="dialog">
    <defaultcontrol always="true">500</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Main background - deep dark -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0A0A12">white.png</texture>
        </control>
        
        <!-- Subtle gradient overlay at top -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>200</height>
            <texture colordiffuse="80141420">white.png</texture>
        </control>
        
        <!-- Netflix-style red accent line at top -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
        </control>
        
        <!-- Back button (top-left) -->
        <control type="button" id="50">
            <left>40</left>
            <top>25</top>
            <width>50</width>
            <height>40</height>
            <label>←</label>
            <font>font16</font>
            <textcolor>FF808080</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="00000000">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <ondown>500</ondown>
            <onright>100</onright>
        </control>
        
        <!-- Page Title -->
        <control type="label" id="100">
            <left>110</left>
            <top>25</top>
            <width>800</width>
            <height>45</height>
            <label>$INFO[Window.Property(page_title)]</label>
            <font>font_MainMenu</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>FF000000</shadowcolor>
        </control>
        
        <!-- Page Subtitle / Category -->
        <control type="label" id="101">
            <left>110</left>
            <top>70</top>
            <width>600</width>
            <height>25</height>
            <label>$INFO[Window.Property(page_subtitle)]</label>
            <font>font12</font>
            <textcolor>FF909090</textcolor>
        </control>
        
        <!-- Time display (top-right) -->
        <control type="label">
            <left>1750</left>
            <top>30</top>
            <width>150</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FF808080</textcolor>
            <align>right</align>
        </control>
        
        <!-- Total items count -->
        <control type="label" id="102">
            <left>1550</left>
            <top>70</top>
            <width>350</width>
            <height>25</height>
            <label>$INFO[Window.Property(total_items)] items</label>
            <font>font12</font>
            <textcolor>FF606060</textcolor>
            <align>right</align>
        </control>
        
        <!-- ======================= -->
        <!-- MAIN GRID - 6 columns x 5 rows = 30 items -->
        <!-- ======================= -->
        <control type="panel" id="500">
            <left>40</left>
            <top>110</top>
            <width>1840</width>
            <height>880</height>
            <onup>50</onup>
            <ondown>600</ondown>
            <onleft>500</onleft>
            <onright>500</onright>
            <viewtype label="Grid">panel</viewtype>
            <orientation>vertical</orientation>
            <scrolltime>200</scrolltime>
            <itemlayout width="306" height="176">
                <!-- Card container -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>290</width>
                    <height>160</height>
                    <texture colordiffuse="20FFFFFF">white.png</texture>
                </control>
                <!-- Poster image (landscape style for grid) -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>290</width>
                    <height>160</height>
                    <aspectratio aligny="top">scale</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Rating badge (top-left) -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>55</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>8</left>
                    <top>8</top>
                    <width>55</width>
                    <height>26</height>
                    <label>★ $INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- Year badge (top-right) -->
                <control type="image">
                    <left>238</left>
                    <top>8</top>
                    <width>60</width>
                    <height>22</height>
                    <texture colordiffuse="80000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <control type="label">
                    <left>238</left>
                    <top>8</top>
                    <width>60</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <!-- Title bar at bottom -->
                <control type="image">
                    <left>8</left>
                    <top>138</top>
                    <width>290</width>
                    <height>30</height>
                    <texture colordiffuse="C0000000">white.png</texture>
                </control>
                <control type="label">
                    <left>14</left>
                    <top>138</top>
                    <width>278</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="306" height="176">
                <!-- Focus glow/border - Netflix red -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>306</width>
                    <height>176</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                </control>
                <!-- Inner card -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>294</width>
                    <height>164</height>
                    <texture colordiffuse="FF1A1A24">white.png</texture>
                </control>
                <!-- Poster image -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>294</width>
                    <height>164</height>
                    <aspectratio aligny="top">scale</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Rating badge (top-left) -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>55</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>6</left>
                    <top>6</top>
                    <width>55</width>
                    <height>26</height>
                    <label>★ $INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- Year badge (top-right) -->
                <control type="image">
                    <left>240</left>
                    <top>6</top>
                    <width>60</width>
                    <height>22</height>
                    <texture colordiffuse="80000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <control type="label">
                    <left>240</left>
                    <top>6</top>
                    <width>60</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <!-- Title bar at bottom - highlighted -->
                <control type="image">
                    <left>6</left>
                    <top>138</top>
                    <width>294</width>
                    <height>32</height>
                    <texture colordiffuse="E0E50914">white.png</texture>
                </control>
                <control type="label">
                    <left>14</left>
                    <top>138</top>
                    <width>282</width>
                    <height>32</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- ======================= -->
        <!-- BOTTOM NAVIGATION BAR -->
        <!-- ======================= -->
        <control type="group" id="599">
            <left>0</left>
            <top>1000</top>
            <width>1920</width>
            <height>80</height>
            
            <!-- Navigation bar background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>80</height>
                <texture colordiffuse="F0101018">white.png</texture>
            </control>
            
            <!-- Top border line -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>1920</width>
                <height>2</height>
                <texture colordiffuse="40FFFFFF">white.png</texture>
            </control>
            
            <!-- Previous Page Button -->
            <control type="button" id="600">
                <left>700</left>
                <top>15</top>
                <width>130</width>
                <height>50</height>
                <label>◀  PREV</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <disabledcolor>FF404040</disabledcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>500</onup>
                <ondown>600</ondown>
                <onleft>600</onleft>
                <onright>650</onright>
                <enable>!String.IsEqual(Window.Property(current_page),1)</enable>
            </control>
            
            <!-- Page Indicator -->
            <control type="label" id="650">
                <left>850</left>
                <top>15</top>
                <width>220</width>
                <height>50</height>
                <label>Page $INFO[Window.Property(current_page)] of $INFO[Window.Property(total_pages)]</label>
                <font>font14</font>
                <textcolor>FF00D4FF</textcolor>
                <align>center</align>
                <aligny>center</aligny>
            </control>
            
            <!-- Next Page Button -->
            <control type="button" id="700">
                <left>1090</left>
                <top>15</top>
                <width>130</width>
                <height>50</height>
                <label>NEXT  ▶</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <disabledcolor>FF404040</disabledcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>500</onup>
                <ondown>700</ondown>
                <onleft>650</onleft>
                <onright>700</onright>
                <enable>!String.IsEqual(Window.Property(current_page),Window.Property(total_pages))</enable>
            </control>
            
            <!-- Items on this page indicator (right side) -->
            <control type="label">
                <left>1500</left>
                <top>25</top>
                <width>380</width>
                <height>30</height>
                <label>Showing $INFO[Window.Property(items_start)]-$INFO[Window.Property(items_end)] of $INFO[Window.Property(total_items)]</label>
                <font>font11</font>
                <textcolor>FF707070</textcolor>
                <align>right</align>
            </control>
        </control>
    </controls>
</window>
