<?xml version="1.0" encoding="UTF-8"?>
<window type="dialog">
    <defaultcontrol always="true">9000</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Background gradient - deep space blue/purple -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0A0B1A">white.png</texture>
        </control>
        
        <!-- Gradient overlay for depth -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="30150830">white.png</texture>
        </control>
        
        <!-- Top header bar -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>70</height>
            <texture colordiffuse="80080810">white.png</texture>
        </control>
        
        <!-- Logo text: ORION -->
        <control type="label" id="1">
            <left>40</left>
            <top>10</top>
            <width>300</width>
            <height>50</height>
            <label>[B][COLOR FF00D4FF]ORION[/COLOR][/B]</label>
            <font>font_MainMenu</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Subtitle: SEARCH -->
        <control type="label" id="2">
            <left>150</left>
            <top>20</top>
            <width>200</width>
            <height>30</height>
            <label>[COLOR FF8B5CF6]SEARCH[/COLOR]</label>
            <font>font12</font>
            <textcolor>FF8B5CF6</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Navigation: Home | Movies | TV Shows | Settings -->
        <control type="label" id="3">
            <left>700</left>
            <top>20</top>
            <width>500</width>
            <height>30</height>
            <label>Home  |  Movies  |  TV Shows  |  [B]Search[/B]  |  Settings</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <align>center</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Time -->
        <control type="label" id="4">
            <left>1700</left>
            <top>20</top>
            <width>200</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Search title with gradient bar -->
        <control type="image">
            <left>40</left>
            <top>90</top>
            <width>1840</width>
            <height>4</height>
            <texture colordiffuse="FF8B5CF6">white.png</texture>
        </control>
        
        <!-- SEARCH RESULTS title -->
        <control type="label" id="100">
            <left>60</left>
            <top>110</top>
            <width>800</width>
            <height>40</height>
            <label>[B]SEARCH RESULTS:[/B] $INFO[Window.Property(search_query)]</label>
            <font>font14</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Results count -->
        <control type="label" id="101">
            <left>1600</left>
            <top>110</top>
            <width>280</width>
            <height>40</height>
            <label>[COLOR FFFF6B9D]($INFO[Window.Property(results_count)] Results)[/COLOR]</label>
            <font>font12</font>
            <textcolor>FFFF6B9D</textcolor>
            <align>right</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Results grid -->
        <control type="panel" id="9000">
            <left>40</left>
            <top>170</top>
            <width>1840</width>
            <height>780</height>
            <onup>9000</onup>
            <ondown>9000</ondown>
            <onleft>9000</onleft>
            <onright>9000</onright>
            <viewtype label="Grid">panel</viewtype>
            <pagecontrol>9001</pagecontrol>
            <scrolltime tween="sine" easing="out">200</scrolltime>
            <orientation>vertical</orientation>
            <itemlayout width="220" height="380">
                <!-- Poster background -->
                <control type="image">
                    <left>10</left>
                    <top>10</top>
                    <width>200</width>
                    <height>300</height>
                    <texture colordiffuse="40202040">white.png</texture>
                </control>
                <!-- Poster image -->
                <control type="image">
                    <left>10</left>
                    <top>10</top>
                    <width>200</width>
                    <height>300</height>
                    <aspectratio>keep</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Title -->
                <control type="label">
                    <left>10</left>
                    <top>315</top>
                    <width>200</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font11</font>
                    <textcolor>FFE0E0FF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Year -->
                <control type="label">
                    <left>10</left>
                    <top>345</top>
                    <width>200</width>
                    <height>25</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FF808090</textcolor>
                    <align>center</align>
                </control>
            </itemlayout>
            <focusedlayout width="220" height="380">
                <!-- Focus glow background -->
                <control type="image">
                    <left>5</left>
                    <top>5</top>
                    <width>210</width>
                    <height>370</height>
                    <texture colordiffuse="FF6366F1">white.png</texture>
                </control>
                <!-- Poster image -->
                <control type="image">
                    <left>10</left>
                    <top>10</top>
                    <width>200</width>
                    <height>300</height>
                    <aspectratio>keep</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Title -->
                <control type="label">
                    <left>10</left>
                    <top>315</top>
                    <width>200</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font11</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Year -->
                <control type="label">
                    <left>10</left>
                    <top>345</top>
                    <width>200</width>
                    <height>25</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Scroll bar -->
        <control type="scrollbar" id="9001">
            <left>1880</left>
            <top>170</top>
            <width>12</width>
            <height>780</height>
            <texturesliderbackground colordiffuse="40404060">white.png</texturesliderbackground>
            <texturesliderbar colordiffuse="FF8B5CF6">white.png</texturesliderbar>
            <texturesliderbarfocus colordiffuse="FF00D4FF">white.png</texturesliderbarfocus>
            <textureslidernib colordiffuse="FF8B5CF6">white.png</textureslidernib>
            <textureslidernibfocus colordiffuse="FF00D4FF">white.png</textureslidernibfocus>
            <orientation>vertical</orientation>
        </control>
        
        <!-- Bottom toolbar -->
        <control type="image">
            <left>0</left>
            <top>980</top>
            <width>1920</width>
            <height>100</height>
            <texture colordiffuse="E0080810">white.png</texture>
        </control>
        
        <!-- Toolbar top border -->
        <control type="image">
            <left>0</left>
            <top>980</top>
            <width>1920</width>
            <height>2</height>
            <texture colordiffuse="FF303050">white.png</texture>
        </control>
        
        <!-- New Search button -->
        <control type="button" id="9010">
            <left>50</left>
            <top>1005</top>
            <width>180</width>
            <height>55</height>
            <label>New Search</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="FF303060">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9010</ondown>
            <onleft>9012</onleft>
            <onright>9011</onright>
        </control>
        
        <!-- Movies filter -->
        <control type="button" id="9011">
            <left>260</left>
            <top>1005</top>
            <width>150</width>
            <height>55</height>
            <label>Movies</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="FF303060">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9011</ondown>
            <onleft>9010</onleft>
            <onright>9012</onright>
        </control>
        
        <!-- TV Shows filter -->
        <control type="button" id="9012">
            <left>440</left>
            <top>1005</top>
            <width>150</width>
            <height>55</height>
            <label>TV Shows</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="FF303060">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9012</ondown>
            <onleft>9011</onleft>
            <onright>9013</onright>
        </control>
        
        <!-- Back button -->
        <control type="button" id="9013">
            <left>1690</left>
            <top>1005</top>
            <width>180</width>
            <height>55</height>
            <label>Back</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="FF6366F1">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9013</ondown>
            <onleft>9012</onleft>
            <onright>9010</onright>
        </control>
    </controls>
</window>
