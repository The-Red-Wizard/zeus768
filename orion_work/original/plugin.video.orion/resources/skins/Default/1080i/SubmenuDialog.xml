<?xml version="1.0" encoding="UTF-8"?>
<!-- Netflix-style Submenu Dialog for Movies, TV Shows, and Trakt Lists -->
<window type="dialog">
    <defaultcontrol always="true">110</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Main background - deep dark gradient -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Hero backdrop image (dynamic - changes with selection) -->
        <control type="image" id="9000">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>650</height>
            <aspectratio>scale</aspectratio>
            <texture fallback="fanart.jpg">$INFO[Window.Property(hero_backdrop)]</texture>
            <colordiffuse>60FFFFFF</colordiffuse>
        </control>
        
        <!-- Hero backdrop gradient overlay (left fade) -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>800</width>
            <height>650</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
            <colordiffuse>E00D0D15</colordiffuse>
        </control>
        
        <!-- Hero backdrop gradient overlay (bottom fade) -->
        <control type="image">
            <left>0</left>
            <top>450</top>
            <width>1920</width>
            <height>250</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Netflix-style red accent line at top -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>3</height>
            <texture colordiffuse="FFE50914">white.png</texture>
        </control>
        
        <!-- Category/Page Title -->
        <control type="label" id="100">
            <left>60</left>
            <top>50</top>
            <width>600</width>
            <height>50</height>
            <label>$INFO[Window.Property(page_title)]</label>
            <font>font_MainMenu</font>
            <textcolor>FFFFFFFF</textcolor>
            <shadowcolor>FF000000</shadowcolor>
        </control>
        
        <!-- Category Subtitle -->
        <control type="label" id="101">
            <left>60</left>
            <top>105</top>
            <width>800</width>
            <height>30</height>
            <label>$INFO[Window.Property(page_subtitle)]</label>
            <font>font12</font>
            <textcolor>FF909090</textcolor>
        </control>
        
        <!-- Hero Info Panel (shows selected item details) -->
        <control type="group" id="150">
            <left>60</left>
            <top>160</top>
            <width>700</width>
            <height>350</height>
            
            <!-- Selected item title -->
            <control type="label" id="151">
                <left>0</left>
                <top>0</top>
                <width>700</width>
                <height>60</height>
                <label>$INFO[Window.Property(selected_title)]</label>
                <font>font35_title</font>
                <textcolor>FFFFFFFF</textcolor>
                <shadowcolor>FF000000</shadowcolor>
            </control>
            
            <!-- Year • Rating • Genre -->
            <control type="label" id="152">
                <left>0</left>
                <top>70</top>
                <width>700</width>
                <height>30</height>
                <label>$INFO[Window.Property(selected_meta)]</label>
                <font>font13</font>
                <textcolor>FF00D4FF</textcolor>
            </control>
            
            <!-- Plot/Overview -->
            <control type="textbox" id="153">
                <left>0</left>
                <top>110</top>
                <width>650</width>
                <height>130</height>
                <label>$INFO[Window.Property(selected_plot)]</label>
                <font>font12</font>
                <textcolor>FFCCCCCC</textcolor>
            </control>
            
            <!-- Watch Now Button -->
            <control type="button" id="160">
                <left>0</left>
                <top>260</top>
                <width>180</width>
                <height>50</height>
                <label>▶  WATCH NOW</label>
                <font>font13</font>
                <textcolor>FF000000</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="FFE50914">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>200</onup>
                <ondown>200</ondown>
                <onleft>160</onleft>
                <onright>161</onright>
            </control>
            
            <!-- More Info Button -->
            <control type="button" id="161">
                <left>200</left>
                <top>260</top>
                <width>150</width>
                <height>50</height>
                <label>ⓘ  INFO</label>
                <font>font13</font>
                <textcolor>FFFFFFFF</textcolor>
                <focusedcolor>FF000000</focusedcolor>
                <texturefocus colordiffuse="FFFFFFFF">white.png</texturefocus>
                <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
                <align>center</align>
                <aligny>center</aligny>
                <onup>200</onup>
                <ondown>200</ondown>
                <onleft>160</onleft>
                <onright>200</onright>
            </control>
        </control>
        
        <!-- Category Filter Tabs (horizontal) -->
        <control type="list" id="110">
            <left>60</left>
            <top>520</top>
            <width>1800</width>
            <height>50</height>
            <orientation>horizontal</orientation>
            <onup>161</onup>
            <ondown>200</ondown>
            <onleft>110</onleft>
            <onright>110</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="180" height="45">
                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>170</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font12</font>
                    <textcolor>FF808080</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="180" height="45">
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>170</width>
                    <height>40</height>
                    <texture colordiffuse="30FFFFFF">white.png</texture>
                </control>
                <!-- Bottom highlight bar -->
                <control type="image">
                    <left>20</left>
                    <top>38</top>
                    <width>130</width>
                    <height>3</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                </control>
                <control type="label">
                    <left>0</left>
                    <top>0</top>
                    <width>170</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Row 1 Title (First content row) -->
        <control type="label" id="201">
            <left>60</left>
            <top>580</top>
            <width>400</width>
            <height>35</height>
            <label>$INFO[Window.Property(row1_title)]</label>
            <font>font13</font>
            <textcolor>FFFFFFFF</textcolor>
        </control>
        
        <!-- Row 1 - Netflix-style horizontal poster carousel -->
        <control type="list" id="200">
            <left>60</left>
            <top>620</top>
            <width>1800</width>
            <height>280</height>
            <orientation>horizontal</orientation>
            <onup>110</onup>
            <ondown>300</ondown>
            <onleft>200</onleft>
            <onright>200</onright>
            <scrolltime>200</scrolltime>
            <pagecontrol>250</pagecontrol>
            <focusposition>0</focusposition>
            <itemlayout width="200" height="265">
                <!-- Card background -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>184</width>
                    <height>250</height>
                    <texture colordiffuse="25FFFFFF">white.png</texture>
                </control>
                <!-- Poster image -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>184</width>
                    <height>250</height>
                    <aspectratio>scale</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Rating badge (top-left) -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <label>★ $INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- HD/4K badge (top-right) -->
                <control type="image">
                    <left>142</left>
                    <top>8</top>
                    <width>50</width>
                    <height>22</height>
                    <texture colordiffuse="E0E50914">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(quality))</visible>
                </control>
                <control type="label">
                    <left>142</left>
                    <top>8</top>
                    <width>50</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(quality))</visible>
                </control>
            </itemlayout>
            <focusedlayout width="200" height="265">
                <!-- Focus glow/border effect -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>200</width>
                    <height>265</height>
                    <texture colordiffuse="FFFFFFFF">white.png</texture>
                </control>
                <!-- Poster image -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>184</width>
                    <height>250</height>
                    <aspectratio>scale</aspectratio>
                    <texture fallback="icon.png">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Title overlay at bottom -->
                <control type="image">
                    <left>8</left>
                    <top>208</top>
                    <width>184</width>
                    <height>50</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                </control>
                <control type="label">
                    <left>12</left>
                    <top>215</top>
                    <width>176</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Rating badge (top-left) -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <label>★ $INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- HD/4K badge (top-right) -->
                <control type="image">
                    <left>142</left>
                    <top>8</top>
                    <width>50</width>
                    <height>22</height>
                    <texture colordiffuse="E0E50914">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(quality))</visible>
                </control>
                <control type="label">
                    <left>142</left>
                    <top>8</top>
                    <width>50</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(quality))</visible>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Row 2 Title (Genre/Categories) -->
        <control type="label" id="301">
            <left>60</left>
            <top>910</top>
            <width>400</width>
            <height>35</height>
            <label>$INFO[Window.Property(row2_title)]</label>
            <font>font13</font>
            <textcolor>FFFFFFFF</textcolor>
            <visible>!String.IsEmpty(Window.Property(row2_title))</visible>
        </control>
        
        <!-- Row 2 - Genres/Categories carousel - Netflix style cards -->
        <control type="list" id="300">
            <left>60</left>
            <top>950</top>
            <width>1800</width>
            <height>120</height>
            <orientation>horizontal</orientation>
            <onup>200</onup>
            <ondown>300</ondown>
            <onleft>300</onleft>
            <onright>300</onright>
            <scrolltime>200</scrolltime>
            <visible>!String.IsEmpty(Window.Property(row2_title))</visible>
            <itemlayout width="180" height="100">
                <!-- Genre card with gradient background -->
                <control type="image">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>85</height>
                    <texture colordiffuse="40303050">white.png</texture>
                </control>
                <!-- Netflix-style accent line at bottom -->
                <control type="image">
                    <left>5</left>
                    <top>87</top>
                    <width>170</width>
                    <height>3</height>
                    <texture colordiffuse="30E50914">white.png</texture>
                </control>
                <control type="label">
                    <left>5</left>
                    <top>5</top>
                    <width>170</width>
                    <height>85</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FFB0B0B0</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="180" height="100">
                <!-- Focus glow/border -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>180</width>
                    <height>100</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                </control>
                <!-- Inner card -->
                <control type="image">
                    <left>4</left>
                    <top>4</top>
                    <width>172</width>
                    <height>88</height>
                    <texture colordiffuse="E0181820">white.png</texture>
                </control>
                <!-- Netflix red accent line at bottom -->
                <control type="image">
                    <left>4</left>
                    <top>86</top>
                    <width>172</width>
                    <height>6</height>
                    <texture colordiffuse="FFE50914">white.png</texture>
                </control>
                <control type="label">
                    <left>4</left>
                    <top>4</top>
                    <width>172</width>
                    <height>82</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font14</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Back button (top-left) -->
        <control type="button" id="50">
            <left>60</left>
            <top>10</top>
            <width>50</width>
            <height>35</height>
            <label>←</label>
            <font>font14</font>
            <textcolor>FF808080</textcolor>
            <focusedcolor>FFFFFFFF</focusedcolor>
            <texturefocus colordiffuse="60FFFFFF">white.png</texturefocus>
            <texturenofocus colordiffuse="00000000">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <ondown>200</ondown>
            <onright>200</onright>
        </control>
        
        <!-- Time display (top-right) -->
        <control type="label">
            <left>1750</left>
            <top>20</top>
            <width>150</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
        </control>
        
        <!-- Page indicator -->
        <control type="label" id="250">
            <left>1750</left>
            <top>890</top>
            <width>150</width>
            <height>25</height>
            <label>$INFO[Window.Property(page_info)]</label>
            <font>font10</font>
            <textcolor>FF808080</textcolor>
            <align>right</align>
        </control>
    </controls>
</window>
