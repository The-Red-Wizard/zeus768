<?xml version="1.0" encoding="utf-8" standalone="yes"?>
<settings>
    <!-- Accounts Section -->
    <category label="Accounts">
        <setting id="tmdb_api_key" type="text" label="TMDB API Key (Optional)" default=""/>
        <setting id="tmdb_key_prompted" type="bool" label="" default="false" visible="false"/>
        
        <!-- Trakt -->
        <setting id="trakt_auth_done" type="bool" label="Trakt Authenticated" default="false" enable="false"/>
        <setting id="trakt_access_token" type="text" label="" default="" visible="false"/>
        <setting id="trakt_refresh_token" type="text" label="" default="" visible="false"/>
        <setting id="trakt_expires" type="text" label="" default="0" visible="false"/>
        <setting id="auth_trakt" type="action" label="[COLOR yellow]Authorize Trakt Account[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_trakt)"/>
        <setting id="revoke_trakt" type="action" label="[COLOR red]Revoke Trakt Authorization[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_trakt)" enable="eq(-4,true)"/>
    </category>
    
    <!-- Debrid Services Section -->
    <category label="Debrid Services">
        <!-- Real-Debrid -->
        <setting id="rd_auth_done" type="bool" label="Real-Debrid Authenticated" default="false" enable="false"/>
        <setting id="rd_access_token" type="text" label="" default="" visible="false"/>
        <setting id="rd_refresh_token" type="text" label="" default="" visible="false"/>
        <setting id="rd_client_id" type="text" label="" default="" visible="false"/>
        <setting id="rd_client_secret" type="text" label="" default="" visible="false"/>
        <setting id="rd_expires" type="text" label="" default="0" visible="false"/>
        <setting id="auth_rd" type="action" label="[COLOR yellow]Authorize Real-Debrid[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_rd)"/>
        <setting id="revoke_rd" type="action" label="[COLOR red]Revoke Real-Debrid[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_rd)" enable="eq(-6,true)"/>
        
        <!-- AllDebrid -->
        <setting id="ad_auth_done" type="bool" label="AllDebrid Authenticated" default="false" enable="false"/>
        <setting id="ad_api_key" type="text" label="" default="" visible="false"/>
        <setting id="auth_ad" type="action" label="[COLOR yellow]Authorize AllDebrid[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_ad)"/>
        <setting id="revoke_ad" type="action" label="[COLOR red]Revoke AllDebrid[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_ad)" enable="eq(-3,true)"/>
        
        <!-- Premiumize -->
        <setting id="pm_auth_done" type="bool" label="Premiumize Authenticated" default="false" enable="false"/>
        <setting id="pm_access_token" type="text" label="" default="" visible="false"/>
        <setting id="auth_pm" type="action" label="[COLOR yellow]Authorize Premiumize[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_pm)"/>
        <setting id="revoke_pm" type="action" label="[COLOR red]Revoke Premiumize[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_pm)" enable="eq(-3,true)"/>
    </category>
    
    <!-- TorBox -->
    <category label="TorBox">
        <setting id="tb_auth_done" type="bool" label="TorBox Authorized" default="false" enable="false"/>
        <setting id="tb_api_key" type="text" label="API Key (auto-filled)" default="" enable="false"/>
        <setting id="auth_tb" type="action" label="[COLOR yellow]Authorize TorBox (Device Code)[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_tb)"/>
        <setting id="revoke_tb" type="action" label="[COLOR red]Revoke TorBox[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_tb)" enable="eq(-3,true)"/>
    </category>
    
    <!-- LinkSnappy -->
    <category label="LinkSnappy">
        <setting id="ls_auth_done" type="bool" label="LinkSnappy Authorized" default="false" enable="false"/>
        <setting id="ls_username" type="text" label="Username" default="" enable="false"/>
        <setting id="ls_password" type="text" label="Password" default="" visible="false"/>
        <setting id="ls_cookie" type="text" label="Cookie" default="" visible="false"/>
        <setting id="auth_ls" type="action" label="[COLOR yellow]Login to LinkSnappy[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=auth_ls)"/>
        <setting id="revoke_ls" type="action" label="[COLOR red]Unlink LinkSnappy[/COLOR]" action="RunPlugin(plugin://plugin.video.trakt_player/?action=revoke_ls)" enable="eq(-5,true)"/>
    </category>
    
    <!-- Playback Settings -->
    <category label="Playback">
        <setting id="preferred_quality" type="select" label="Preferred Quality" default="1" values="4K/2160p|1080p|720p|480p"/>
        <setting id="auto_play" type="bool" label="Auto-Play Best Quality" default="true"/>
        <setting id="quality_fallback" type="bool" label="Auto-Fallback to Lower Quality" default="true"/>
        <setting type="sep"/>
        <setting type="lsep" label="Pre-Cache Next Episode"/>
        <setting id="enable_precache" type="bool" label="Enable Pre-Cache Next Episode" default="true"/>
        <setting id="precache_notifications" type="bool" label="Show Pre-Cache Notifications" default="true" enable="eq(-1,true)"/>
    </category>
    
    <!-- Notifications -->
    <category label="Notifications">
        <setting type="lsep" label="New Episode Alerts"/>
        <setting id="enable_notifications" type="bool" label="Enable New Episode Notifications" default="true"/>
        <setting id="notification_style" type="select" label="Notification Style" default="0" values="Individual|Summary" enable="eq(-1,true)"/>
    </category>
    
    <!-- Scraper Settings -->
    <category label="Scrapers">
        <setting id="enable_torrent_scrapers" type="bool" label="Enable Torrent Scrapers (Requires Debrid)" default="true"/>
        <setting id="enable_piratebay" type="bool" label="Enable PirateBay" default="true" enable="eq(-1,true)"/>
        <setting id="enable_1337x" type="bool" label="Enable 1337x" default="true" enable="eq(-2,true)"/>
        <setting id="enable_rarbg" type="bool" label="Enable RARBG/TorrentAPI" default="false" enable="eq(-3,true)"/>
        <setting id="enable_torrentgalaxy" type="bool" label="Enable TorrentGalaxy" default="false" enable="eq(-4,true)"/>
    </category>
</settings>
