<?xml version="1.0" encoding="UTF-8"?>
<!-- Orion - Netflix-style Search Results - Cyan Theme, Landscape Cards -->
<window type="dialog">
    <defaultcontrol always="true">9000</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Background - dark theme -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0D0D15">white.png</texture>
        </control>
        
        <!-- Cyan accent line at top -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>3</height>
            <texture colordiffuse="FF00D4FF">white.png</texture>
        </control>
        
        <!-- Top header bar -->
        <control type="image">
            <left>0</left>
            <top>3</top>
            <width>1920</width>
            <height>67</height>
            <texture colordiffuse="E0080810">white.png</texture>
        </control>
        
        <!-- Logo text: ORION -->
        <control type="label" id="1">
            <left>40</left>
            <top>10</top>
            <width>120</width>
            <height>50</height>
            <label>ORION</label>
            <font>font_MainMenu</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Subtitle: SEARCH -->
        <control type="label" id="2">
            <left>150</left>
            <top>20</top>
            <width>200</width>
            <height>30</height>
            <label>SEARCH</label>
            <font>font12</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Time -->
        <control type="label" id="4">
            <left>1700</left>
            <top>20</top>
            <width>200</width>
            <height>30</height>
            <label>$INFO[System.Time]</label>
            <font>font12</font>
            <textcolor>FFFFFFFF</textcolor>
            <align>right</align>
            <aligny>center</aligny>
        </control>
        
        <!-- SEARCH RESULTS title -->
        <control type="label" id="100">
            <left>60</left>
            <top>85</top>
            <width>800</width>
            <height>40</height>
            <label>SEARCH RESULTS: $INFO[Window.Property(search_query)]</label>
            <font>font14</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Results count -->
        <control type="label" id="101">
            <left>1600</left>
            <top>85</top>
            <width>280</width>
            <height>40</height>
            <label>($INFO[Window.Property(results_count)] Results)</label>
            <font>font12</font>
            <textcolor>FF00D4FF</textcolor>
            <align>right</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Results grid - LANDSCAPE cards, NO name banners -->
        <control type="panel" id="9000">
            <left>40</left>
            <top>140</top>
            <width>1840</width>
            <height>810</height>
            <onup>9000</onup>
            <ondown>9000</ondown>
            <onleft>9000</onleft>
            <onright>9000</onright>
            <viewtype label="Grid">panel</viewtype>
            <pagecontrol>9001</pagecontrol>
            <scrolltime tween="sine" easing="out">200</scrolltime>
            <orientation>vertical</orientation>
            <itemlayout width="306" height="190">
                <!-- Card background -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>290</width>
                    <height>170</height>
                    <texture colordiffuse="25FFFFFF">white.png</texture>
                </control>
                <!-- Landscape poster image -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>290</width>
                    <height>170</height>
                    <aspectratio>scale</aspectratio>
                    <texture fallback="fanart.jpg">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Rating badge (top-left) -->
                <control type="image">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>8</left>
                    <top>8</top>
                    <width>50</width>
                    <height>26</height>
                    <label>$INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- Year badge (top-right) -->
                <control type="image">
                    <left>238</left>
                    <top>8</top>
                    <width>60</width>
                    <height>22</height>
                    <texture colordiffuse="80000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <control type="label">
                    <left>238</left>
                    <top>8</top>
                    <width>60</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FFCCCCCC</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
            </itemlayout>
            <focusedlayout width="306" height="190">
                <!-- Cyan focus border -->
                <control type="image">
                    <left>0</left>
                    <top>0</top>
                    <width>306</width>
                    <height>190</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <!-- Inner card -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>294</width>
                    <height>178</height>
                    <texture colordiffuse="FF1A1A24">white.png</texture>
                </control>
                <!-- Landscape poster -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>294</width>
                    <height>178</height>
                    <aspectratio>scale</aspectratio>
                    <texture fallback="fanart.jpg">$INFO[ListItem.Art(poster)]</texture>
                </control>
                <!-- Rating badge -->
                <control type="image">
                    <left>6</left>
                    <top>6</top>
                    <width>50</width>
                    <height>26</height>
                    <texture colordiffuse="E0000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <control type="label">
                    <left>6</left>
                    <top>6</top>
                    <width>50</width>
                    <height>26</height>
                    <label>$INFO[ListItem.Property(rating)]</label>
                    <font>font10</font>
                    <textcolor>FFFFCC00</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(rating))</visible>
                </control>
                <!-- Year badge -->
                <control type="image">
                    <left>240</left>
                    <top>6</top>
                    <width>60</width>
                    <height>22</height>
                    <texture colordiffuse="80000000">white.png</texture>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
                <control type="label">
                    <left>240</left>
                    <top>6</top>
                    <width>60</width>
                    <height>22</height>
                    <label>$INFO[ListItem.Property(year)]</label>
                    <font>font10</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>center</align>
                    <aligny>center</aligny>
                    <visible>!String.IsEmpty(ListItem.Property(year))</visible>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Scroll bar -->
        <control type="scrollbar" id="9001">
            <left>1880</left>
            <top>140</top>
            <width>12</width>
            <height>810</height>
            <texturesliderbackground colordiffuse="40404060">white.png</texturesliderbackground>
            <texturesliderbar colordiffuse="FF00D4FF">white.png</texturesliderbar>
            <texturesliderbarfocus colordiffuse="FFFFFFFF">white.png</texturesliderbarfocus>
            <textureslidernib colordiffuse="FF00D4FF">white.png</textureslidernib>
            <textureslidernibfocus colordiffuse="FFFFFFFF">white.png</textureslidernibfocus>
            <orientation>vertical</orientation>
        </control>
        
        <!-- Bottom toolbar -->
        <control type="image">
            <left>0</left>
            <top>965</top>
            <width>1920</width>
            <height>115</height>
            <texture colordiffuse="F0080810">white.png</texture>
        </control>
        
        <!-- Toolbar top border -->
        <control type="image">
            <left>0</left>
            <top>965</top>
            <width>1920</width>
            <height>2</height>
            <texture colordiffuse="40FFFFFF">white.png</texture>
        </control>
        
        <!-- New Search button -->
        <control type="button" id="9010">
            <left>50</left>
            <top>990</top>
            <width>180</width>
            <height>55</height>
            <label>New Search</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9010</ondown>
            <onleft>9013</onleft>
            <onright>9011</onright>
        </control>
        
        <!-- Movies filter -->
        <control type="button" id="9011">
            <left>260</left>
            <top>990</top>
            <width>150</width>
            <height>55</height>
            <label>Movies</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9011</ondown>
            <onleft>9010</onleft>
            <onright>9012</onright>
        </control>
        
        <!-- TV Shows filter -->
        <control type="button" id="9012">
            <left>440</left>
            <top>990</top>
            <width>150</width>
            <height>55</height>
            <label>TV Shows</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9012</ondown>
            <onleft>9011</onleft>
            <onright>9013</onright>
        </control>
        
        <!-- Back button -->
        <control type="button" id="9013">
            <left>1690</left>
            <top>990</top>
            <width>180</width>
            <height>55</height>
            <label>Back</label>
            <font>font12</font>
            <textcolor>FFE0E0FF</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="40202040">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>9000</onup>
            <ondown>9013</ondown>
            <onleft>9012</onleft>
            <onright>9010</onright>
        </control>
    </controls>
</window>
