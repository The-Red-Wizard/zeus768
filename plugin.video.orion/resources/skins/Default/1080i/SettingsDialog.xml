<?xml version="1.0" encoding="UTF-8"?>
<!-- Orion - Netflix-style Settings Dialog - Cyan Theme -->
<window type="dialog">
    <defaultcontrol always="true">100</defaultcontrol>
    <zorder>1</zorder>
    <coordinates>
        <system>1</system>
        <left>0</left>
        <top>0</top>
    </coordinates>
    
    <controls>
        <!-- Background - dark -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="FF0A0A12">white.png</texture>
        </control>
        
        <!-- Cyan accent line at top -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>3</height>
            <texture colordiffuse="FF00D4FF">white.png</texture>
        </control>
        
        <!-- Header bar -->
        <control type="image">
            <left>0</left>
            <top>3</top>
            <width>1920</width>
            <height>77</height>
            <texture colordiffuse="E0080810">white.png</texture>
        </control>
        
        <!-- Logo: ORION -->
        <control type="label">
            <left>60</left>
            <top>15</top>
            <width>200</width>
            <height>50</height>
            <label>ORION</label>
            <font>font_MainMenu</font>
            <textcolor>FF00D4FF</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- SETTINGS title -->
        <control type="label">
            <left>200</left>
            <top>25</top>
            <width>400</width>
            <height>35</height>
            <label>SETTINGS</label>
            <font>font14</font>
            <textcolor>FF808090</textcolor>
            <align>left</align>
            <aligny>center</aligny>
        </control>
        
        <!-- Left sidebar - setting categories -->
        <control type="image">
            <left>0</left>
            <top>80</top>
            <width>300</width>
            <height>1000</height>
            <texture colordiffuse="F0080810">white.png</texture>
        </control>
        
        <!-- Right border of sidebar -->
        <control type="image">
            <left>298</left>
            <top>80</top>
            <width>2</width>
            <height>1000</height>
            <texture colordiffuse="40404060">white.png</texture>
        </control>
        
        <!-- Category list -->
        <control type="list" id="100">
            <left>0</left>
            <top>100</top>
            <width>300</width>
            <height>800</height>
            <onup>100</onup>
            <ondown>100</ondown>
            <onleft>100</onleft>
            <onright>200</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="300" height="65">
                <control type="label">
                    <left>30</left>
                    <top>15</top>
                    <width>260</width>
                    <height>35</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FF808090</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="300" height="65">
                <control type="image">
                    <left>0</left>
                    <top>5</top>
                    <width>300</width>
                    <height>55</height>
                    <texture colordiffuse="40303060">white.png</texture>
                </control>
                <control type="image">
                    <left>0</left>
                    <top>5</top>
                    <width>4</width>
                    <height>55</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <control type="label">
                    <left>30</left>
                    <top>15</top>
                    <width>260</width>
                    <height>35</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Right panel - setting items for selected category -->
        <control type="list" id="200">
            <left>330</left>
            <top>100</top>
            <width>1550</width>
            <height>800</height>
            <onup>200</onup>
            <ondown>200</ondown>
            <onleft>100</onleft>
            <onright>200</onright>
            <scrolltime>200</scrolltime>
            <itemlayout width="1550" height="70">
                <!-- Row background -->
                <control type="image">
                    <left>0</left>
                    <top>2</top>
                    <width>1550</width>
                    <height>66</height>
                    <texture colordiffuse="15FFFFFF">white.png</texture>
                </control>
                <!-- Setting label -->
                <control type="label">
                    <left>20</left>
                    <top>5</top>
                    <width>900</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FFD0D0E0</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Setting description -->
                <control type="label">
                    <left>20</left>
                    <top>35</top>
                    <width>900</width>
                    <height>25</height>
                    <label>$INFO[ListItem.Label2]</label>
                    <font>font10</font>
                    <textcolor>FF606070</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Current value -->
                <control type="label">
                    <left>950</left>
                    <top>15</top>
                    <width>580</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Property(value)]</label>
                    <font>font12</font>
                    <textcolor>FF00D4FF</textcolor>
                    <align>right</align>
                    <aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout width="1550" height="70">
                <!-- Focused row background -->
                <control type="image">
                    <left>0</left>
                    <top>2</top>
                    <width>1550</width>
                    <height>66</height>
                    <texture colordiffuse="40303060">white.png</texture>
                </control>
                <!-- Cyan left accent -->
                <control type="image">
                    <left>0</left>
                    <top>2</top>
                    <width>4</width>
                    <height>66</height>
                    <texture colordiffuse="FF00D4FF">white.png</texture>
                </control>
                <!-- Setting label -->
                <control type="label">
                    <left>20</left>
                    <top>5</top>
                    <width>900</width>
                    <height>30</height>
                    <label>$INFO[ListItem.Label]</label>
                    <font>font13</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Setting description -->
                <control type="label">
                    <left>20</left>
                    <top>35</top>
                    <width>900</width>
                    <height>25</height>
                    <label>$INFO[ListItem.Label2]</label>
                    <font>font10</font>
                    <textcolor>FF909090</textcolor>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Current value (focused) -->
                <control type="label">
                    <left>950</left>
                    <top>15</top>
                    <width>580</width>
                    <height>40</height>
                    <label>$INFO[ListItem.Property(value)]</label>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <align>right</align>
                    <aligny>center</aligny>
                </control>
            </focusedlayout>
        </control>
        
        <!-- Bottom bar -->
        <control type="image">
            <left>0</left>
            <top>960</top>
            <width>1920</width>
            <height>120</height>
            <texture colordiffuse="F0080810">white.png</texture>
        </control>
        
        <!-- Bottom bar top border -->
        <control type="image">
            <left>0</left>
            <top>960</top>
            <width>1920</width>
            <height>2</height>
            <texture colordiffuse="40FFFFFF">white.png</texture>
        </control>
        
        <!-- Save button -->
        <control type="button" id="300">
            <left>700</left>
            <top>985</top>
            <width>200</width>
            <height>55</height>
            <label>SAVE</label>
            <font>font13</font>
            <textcolor>FF000000</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="80FFFFFF">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>200</onup>
            <onleft>300</onleft>
            <onright>301</onright>
        </control>
        
        <!-- Close button -->
        <control type="button" id="301">
            <left>1020</left>
            <top>985</top>
            <width>200</width>
            <height>55</height>
            <label>CLOSE</label>
            <font>font13</font>
            <textcolor>FFD0D0E0</textcolor>
            <focusedcolor>FF000000</focusedcolor>
            <texturefocus colordiffuse="FF00D4FF">white.png</texturefocus>
            <texturenofocus colordiffuse="40FFFFFF">white.png</texturenofocus>
            <align>center</align>
            <aligny>center</aligny>
            <onup>200</onup>
            <onleft>300</onleft>
            <onright>301</onright>
        </control>
        
        <!-- Version info -->
        <control type="label">
            <left>60</left>
            <top>995</top>
            <width>400</width>
            <height>30</height>
            <label>Orion v3.6.2</label>
            <font>font10</font>
            <textcolor>FF404050</textcolor>
        </control>
    </controls>
</window>
