<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<settings>
    <category label="General">
        <setting id="auto_play" type="bool" label="Autoplay (auto-select best source)" default="false"/>
        <setting id="source_timeout" type="slider" label="Source timeout (seconds)" default="30" range="10,5,120"/>
        <setting id="max_results" type="slider" label="Maximum results per scraper" default="50" range="10,10,100"/>
        <setting id="premiere_international" type="bool" label="Show International Premieres" default="false"/>
    </category>

    <category label="Playback">
        <setting id="filter_cam" type="bool" label="Filter CAM/TS quality" default="true"/>
        <setting id="min_quality" type="labelenum" label="Minimum quality" values="Any|480p|720p|1080p|4K" default="Any"/>
        <setting id="sort_by" type="labelenum" label="Sort sources by" values="Seeds|Quality|Size" default="Seeds"/>
        <setting id="preferred_quality" type="labelenum" label="Preferred quality" values="2160p|1080p|720p|480p" default="1080p"/>
        <setting id="next_episode_enabled" type="bool" label="Enable Up Next (auto next episode)" default="true"/>
        <setting id="skip_intro_enabled" type="bool" label="Enable Skip Intro prompt" default="true"/>
        <setting id="skip_intro_duration" type="slider" label="Skip Intro duration (seconds)" default="90" range="30,5,180" enable="eq(-1,true)"/>
    </category>

    <category label="Trakt">
        <setting id="trakt_enabled" type="bool" label="Enable Trakt" default="false"/>
        <setting id="trakt_access_token" type="text" label="Access Token" default="" visible="false"/>
        <setting id="trakt_refresh_token" type="text" label="Refresh Token" default="" visible="false"/>
        <setting id="trakt_expires" type="text" label="Expires" default="0" visible="false"/>
    </category>

    <category label="PunchPlay">
        <setting type="lsep" label="PunchPlay.tv (Trakt alternative)"/>
        <setting id="punchplay_enabled" type="bool" label="Enable PunchPlay scrobbling" default="false"/>
        <setting id="punchplay_mark_watched" type="bool" label="Mark watched on PunchPlay (at end of playback)" default="true" enable="eq(-1,true)"/>
        <setting id="punchplay_mirror_trakt" type="bool" label="Mirror Trakt 'mark watched' actions to PunchPlay" default="true" enable="eq(-2,true)"/>
        <setting id="punchplay_login" type="action" label="Login to PunchPlay" action="RunPlugin(plugin://plugin.video.salts/?mode=punchplay_auth)"/>
        <setting id="punchplay_logout" type="action" label="Logout of PunchPlay" action="RunPlugin(plugin://plugin.video.salts/?mode=punchplay_revoke)"/>
        <setting id="punchplay_status" type="action" label="Check PunchPlay status" action="RunPlugin(plugin://plugin.video.salts/?mode=punchplay_status)"/>
        <setting id="punchplay_base_url" type="text" label="Backend URL (advanced)" default="https://punchplay.tv"/>
        <setting id="punchplay_continue_watching" type="bool" label="Show 'Continue Watching' on main menu (when API available)" default="true"/>
        <setting id="punchplay_access_token" type="text" label="Access Token" default="" visible="false"/>
        <setting id="punchplay_refresh_token" type="text" label="Refresh Token" default="" visible="false"/>
        <setting id="punchplay_expires" type="text" label="Expires" default="0" visible="false"/>
    </category>

    <category label="Debrid Services">
        <setting type="lsep" label="Real-Debrid"/>
        <setting id="realdebrid_enabled" type="bool" label="Enable Real-Debrid" default="false"/>
        <setting id="realdebrid_token" type="text" label="Access Token" default="" visible="false"/>
        <setting id="realdebrid_refresh" type="text" label="Refresh Token" default="" visible="false"/>
        <setting id="realdebrid_client_id" type="text" label="Client ID" default="" visible="false"/>
        <setting id="realdebrid_client_secret" type="text" label="Client Secret" default="" visible="false"/>
        <setting id="realdebrid_expires" type="text" label="Expires" default="0" visible="false"/>
        <setting type="lsep" label="Premiumize"/>
        <setting id="premiumize_enabled" type="bool" label="Enable Premiumize" default="false"/>
        <setting id="premiumize_token" type="text" label="API Key" default="" visible="false"/>
        <setting type="lsep" label="AllDebrid"/>
        <setting id="alldebrid_enabled" type="bool" label="Enable AllDebrid" default="false"/>
        <setting id="alldebrid_token" type="text" label="API Key" default="" visible="false"/>
        <setting type="lsep" label="TorBox"/>
        <setting id="torbox_enabled" type="bool" label="Enable TorBox" default="false"/>
        <setting id="torbox_token" type="text" label="API Key" default="" visible="false"/>
        <setting id="torbox_cache_check" type="bool" label="Show TorBox cached torrents in source list" default="true" enable="eq(-2,true)"/>
        <setting id="torbox_store_to_cloud" type="bool" label="Keep resolved torrents in TorBox cloud (do not auto-delete)" default="false" enable="eq(-3,true)"/>
    </category>

    <category label="Stremio Addons">
        <setting type="lsep" label="Stremio Free Addons"/>
        <setting id="braflix_enabled" type="bool" label="Braflix" default="true"/>
        <setting id="streamingcommunity_enabled" type="bool" label="StreamingCommunity" default="true"/>
        <setting id="themoviearchive_enabled" type="bool" label="TheMovieArchive" default="true"/>
        <setting id="publicdomainmovies_enabled" type="bool" label="PublicDomainMovies" default="true"/>
        <setting id="watchhub_enabled" type="bool" label="WatchHub" default="true"/>
        <setting id="cinemeta_enabled" type="bool" label="Cinemeta" default="false"/>
        <setting id="knightcrawler_enabled" type="bool" label="KnightCrawler" default="true"/>
        <setting id="jackettio_enabled" type="bool" label="Jackettio" default="true"/>
        <setting id="orionoid_enabled" type="bool" label="Orionoid" default="true"/>
        <setting id="tpbplus_enabled" type="bool" label="TPB Plus" default="true"/>
        <setting id="yts_stremio_enabled" type="bool" label="YTS Stremio" default="true"/>
        <setting id="rarbg_stremio_enabled" type="bool" label="RARBG Stremio" default="true"/>
        <setting id="torrentio_free_enabled" type="bool" label="Torrentio (Free Mode)" default="true"/>
        <setting id="aiostreams_enabled" type="bool" label="AIOStreams" default="true"/>
        <setting id="stremthru_enabled" type="bool" label="StremThru" default="true"/>
        <setting id="mediaflow_enabled" type="bool" label="MediaFlow" default="true"/>
        <setting id="ddlstream_enabled" type="bool" label="DDLStream" default="true"/>
        <setting id="plutotv_stremio_enabled" type="bool" label="PlutoTV" default="true"/>
        <setting id="tubi_stremio_enabled" type="bool" label="Tubi" default="true"/>
        <setting id="localtv_enabled" type="bool" label="LocalTV" default="false"/>
        <setting id="opensubs_enabled" type="bool" label="OpenSubtitles" default="false"/>
        <setting type="lsep" label="Stremio Debrid Addons"/>
        <setting id="torrentio_enabled" type="bool" label="Torrentio" default="true"/>
        <setting id="torrentio_url" type="text" label="    Torrentio base URL (paste your configured manifest URL)" default=""/>
        <setting id="mediafusion_enabled" type="bool" label="MediaFusion" default="true"/>
        <setting id="mediafusion_url" type="text" label="    MediaFusion base URL (paste your configured manifest URL)" default=""/>
        <setting id="comet_enabled" type="bool" label="Comet" default="true"/>
        <setting id="comet_url" type="text" label="    Comet base URL (paste your configured manifest URL)" default=""/>
        <setting id="easynews_enabled" type="bool" label="EasyNews+" default="false"/>
    </category>

    <category label="Torrent Sites">
        <setting type="lsep" label="Primary"/>
        <setting id="1337x_enabled" type="bool" label="1337x" default="true"/>
        <setting id="yts_enabled" type="bool" label="YTS (Movies)" default="true"/>
        <setting id="eztv_enabled" type="bool" label="EZTV (TV)" default="true"/>
        <setting id="thepiratebay_enabled" type="bool" label="ThePirateBay" default="true"/>
        <setting id="torrentgalaxy_enabled" type="bool" label="TorrentGalaxy" default="true"/>
        <setting id="solidtorrents_enabled" type="bool" label="SolidTorrents" default="true"/>
        <setting type="lsep" label="Secondary"/>
        <setting id="limetorrents_enabled" type="bool" label="LimeTorrents" default="true"/>
        <setting id="kickass_enabled" type="bool" label="Kickass" default="true"/>
        <setting id="torrentdownload_enabled" type="bool" label="TorrentDownload" default="true"/>
        <setting type="lsep" label="Additional"/>
        <setting id="bitsearch_enabled" type="bool" label="BitSearch" default="true"/>
        <setting id="torrentdownloads2_enabled" type="bool" label="TorrentDownloads" default="true"/>
        <setting id="torlock_enabled" type="bool" label="TorLock" default="true"/>
        <setting id="torrentfunk_enabled" type="bool" label="TorrentFunk" default="true"/>
        <setting id="yourbittorrent_enabled" type="bool" label="YourBittorrent" default="true"/>
        <setting id="leetx_enabled" type="bool" label="LeetX (1337x Mirror)" default="true"/>
        <setting id="torrentscsv_enabled" type="bool" label="TorrentsCSV" default="true"/>
        <setting id="solidtorrents2_enabled" type="bool" label="SolidTorrents2" default="true"/>
    </category>

    <category label="Anime">
        <setting type="lsep" label="Anime Torrent Sites"/>
        <setting id="nyaa_enabled" type="bool" label="Nyaa" default="true"/>
        <setting id="subsplease_enabled" type="bool" label="SubsPlease" default="true"/>
        <setting id="tokyotosho_enabled" type="bool" label="TokyoTosho" default="true"/>
        <setting id="animetosho_enabled" type="bool" label="AnimeTosho" default="true"/>
        <setting type="lsep" label="Anime Stremio"/>
        <setting id="anime_stremio_enabled" type="bool" label="Anime Stremio" default="true"/>
        <setting id="animetosho_stremio_enabled" type="bool" label="AnimeTosho Stremio" default="true"/>
    </category>

    <category label="Regional">
        <setting type="lsep" label="Russian"/>
        <setting id="rutracker_enabled" type="bool" label="RuTracker" default="true"/>
        <setting id="rutor_enabled" type="bool" label="RuTor" default="true"/>
        <setting id="nnm-club_enabled" type="bool" label="NNM-Club" default="true"/>
        <setting type="lsep" label="Chinese"/>
        <setting id="btbtt_enabled" type="bool" label="BTBTT" default="true"/>
        <setting type="lsep" label="French"/>
        <setting id="torrent9_enabled" type="bool" label="Torrent9" default="true"/>
    </category>

    <category label="Aggregators">
        <setting type="lsep" label="Jackett"/>
        <setting id="jackett_enabled" type="bool" label="Enable Jackett" default="false"/>
        <setting id="jackett_url" type="text" label="Jackett URL" default="http://localhost:9117" enable="eq(-1,true)"/>
        <setting id="jackett_api_key" type="text" label="Jackett API Key" default="" enable="eq(-2,true)"/>
        <setting type="lsep" label="Prowlarr"/>
        <setting id="prowlarr_enabled" type="bool" label="Enable Prowlarr" default="false"/>
        <setting id="prowlarr_url" type="text" label="Prowlarr URL" default="http://localhost:9696" enable="eq(-1,true)"/>
        <setting id="prowlarr_api_key" type="text" label="Prowlarr API Key" default="" enable="eq(-2,true)"/>
        <setting type="lsep" label="TorrentAPI"/>
        <setting id="torrentapi_enabled" type="bool" label="TorrentAPI" default="false"/>
        <setting type="lsep" label="PlanetScrapers (Torrentio + TPB + TGx + 1337x)"/>
        <setting id="planetscrapers_enabled" type="bool" label="Enable PlanetScrapers aggregator" default="true"/>
        <setting id="enable_torrentio" type="bool" label="    PlanetScrapers: Torrentio backend" default="true" enable="eq(-1,true)"/>
        <setting id="enable_piratebay" type="bool" label="    PlanetScrapers: PirateBay backend" default="true" enable="eq(-2,true)"/>
        <setting id="enable_torrentgalaxy" type="bool" label="    PlanetScrapers: TorrentGalaxy backend" default="true" enable="eq(-3,true)"/>
        <setting id="enable_1337x" type="bool" label="    PlanetScrapers: 1337x backend" default="true" enable="eq(-4,true)"/>
    </category>

    <category label="Cache">
        <setting id="source_cache_enabled" type="bool" label="Enable source caching" default="true"/>
        <setting id="source_cache_hours" type="slider" label="Source cache duration (hours)" default="2" range="1,1,12" enable="eq(-1,true)"/>
        <setting id="preemptive_scrape" type="bool" label="Pre-emptive scrape next episode" default="true"/>
        <setting id="cache_duration" type="slider" label="General cache duration (hours)" default="8" range="1,1,24"/>
    </category>

    <category label="Advanced">
        <setting id="debug_enabled" type="bool" label="Enable debug logging" default="false"/>
        <setting id="parallel_scrapers" type="slider" label="Max parallel scrapers" default="50" range="10,5,100"/>
        <setting id="scraper_timeout" type="slider" label="Scraper timeout (seconds, all scrapers must finish in this time)" default="120" range="30,10,300"/>
        <setting id="show_all_at_once" type="bool" label="Show all sources at once (no progressive results)" default="true"/>
        <setting type="lsep" label="AI Search"/>
        <setting id="ai_search_enabled" type="bool" label="Enable AI Search" default="true"/>
        <setting id="ai_api_key" type="text" label="OpenAI API Key" default="sk-emergent-4Ed53090b4b04F8606" option="hidden"/>
        <setting id="ai_model" type="labelenum" label="AI Model" values="gpt-4o-mini|gpt-4o|gpt-5.2" default="0"/>
    </category>
</settings>
