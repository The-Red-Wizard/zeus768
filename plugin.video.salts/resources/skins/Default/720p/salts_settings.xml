<?xml version="1.0" encoding="UTF-8"?>
<!--
    SALTS - Custom Settings Window
    Rendered by salts_lib.settings_window.SaltsSettingsWindow.

    Reference resolution : 1280x720
    Background           : addon fanart.jpg (no inner dialog card)

    Row visuals are baked into the ListItem labels via BBCode in Python,
    so this skin has NO per-row <visible> conditions inside item layouts.
    One Label control + one Label2 control per layout = nothing can
    overlap the toggle/value widget.

    Control IDs used by Python:
        100  Categories list (left sidebar)
        200  Settings list   (right panel)
        300  OK / Close button
        301  Defaults button
        302  Search button
        400  Description textbox (footer)
        500  Right-panel title label (active category name)
        501  Subtitle next to SALTS in header
-->
<window type="dialog" id="13120">
    <defaultcontrol always="true">100</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx>
        <posy>0</posy>
    </coordinates>

    <animation effect="fade" time="160">WindowOpen</animation>
    <animation effect="fade" time="120">WindowClose</animation>

    <controls>
        <!-- ===== Fanart backdrop (the only background) ===== -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1280</width><height>720</height>
            <texture>../../../../fanart.jpg</texture>
            <aspectratio>scale</aspectratio>
        </control>
        <!-- Light vignette overlay just for text contrast -->
        <control type="image">
            <left>0</left><top>0</top>
            <width>1280</width><height>720</height>
            <texture>black-back.png</texture>
            <colordiffuse>80000000</colordiffuse>
            <aspectratio>stretch</aspectratio>
        </control>

        <!-- ===== Header strip ===== -->
        <control type="image">
            <left>40</left><top>40</top><width>1200</width><height>72</height>
            <texture>black-back.png</texture><colordiffuse>CC000000</colordiffuse>
        </control>
        <control type="image">
            <left>40</left><top>112</top><width>1200</width><height>2</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <control type="image">
            <left>64</left><top>52</top><width>48</width><height>48</height>
            <texture>../../../../icon.png</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>128</left><top>52</top><width>700</width><height>26</height>
            <font>font13</font>
            <textcolor>FFFFD700</textcolor>
            <label>SALTS</label>
            <align>left</align><aligny>center</aligny>
        </control>
        <control type="label" id="501">
            <left>128</left><top>80</top><width>700</width><height>22</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>Settings  |  Stream All The Sources</label>
            <align>left</align><aligny>center</aligny>
        </control>
        <control type="label">
            <left>820</left><top>62</top><width>400</width><height>28</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>Left/Right move between panels  |  OK to edit</label>
            <align>right</align><aligny>center</aligny>
        </control>

        <!-- ===== Left sidebar ===== -->
        <control type="image">
            <left>40</left><top>114</top><width>340</width><height>456</height>
            <texture>black-back.png</texture><colordiffuse>CC000000</colordiffuse>
        </control>
        <control type="label">
            <left>60</left><top>126</top><width>300</width><height>22</height>
            <font>font11</font>
            <textcolor>FFFFD700</textcolor>
            <label>CATEGORIES</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <control type="list" id="100">
            <left>52</left><top>158</top><width>316</width><height>404</height>
            <onleft>300</onleft>
            <onright>200</onright>
            <onup>100</onup>
            <ondown>100</ondown>
            <pagecontrol>-</pagecontrol>
            <scrolltime>180</scrolltime>
            <itemlayout height="44" width="316">
                <control type="label">
                    <left>16</left><top>2</top><width>284</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFE6EDF3</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </itemlayout>
            <focusedlayout height="44" width="316">
                <!-- Bright fill so focused row is unmistakable -->
                <control type="image">
                    <left>0</left><top>2</top><width>316</width><height>40</height>
                    <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
                </control>
                <!-- Inner dark fill leaving 4px gold border on all sides -->
                <control type="image">
                    <left>4</left><top>6</top><width>308</width><height>32</height>
                    <texture>black-back.png</texture><colordiffuse>FF0d1117</colordiffuse>
                </control>
                <control type="label">
                    <left>16</left><top>2</top><width>284</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFFFD700</textcolor>
                    <label>[B]$INFO[ListItem.Label][/B]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </focusedlayout>
            <content/>
        </control>

        <!-- ===== Right panel ===== -->
        <control type="image">
            <left>400</left><top>114</top><width>840</width><height>456</height>
            <texture>black-back.png</texture><colordiffuse>CC000000</colordiffuse>
        </control>
        <control type="label" id="500">
            <left>420</left><top>126</top><width>800</width><height>22</height>
            <font>font11</font>
            <textcolor>FFFFD700</textcolor>
            <label>OPTIONS</label>
            <align>left</align><aligny>center</aligny>
        </control>
        <control type="image">
            <left>420</left><top>152</top><width>40</width><height>2</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <control type="list" id="200">
            <left>420</left><top>162</top><width>800</width><height>398</height>
            <onleft>100</onleft>
            <onright>200</onright>
            <onup>200</onup>
            <ondown>200</ondown>
            <pagecontrol>-</pagecontrol>
            <scrolltime>180</scrolltime>

            <itemlayout height="44" width="800">
                <control type="label">
                    <left>16</left><top>2</top><width>500</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFE6EDF3</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
                <control type="label">
                    <left>520</left><top>2</top><width>264</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFE6EDF3</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                    <align>right</align><aligny>center</aligny>
                </control>
            </itemlayout>

            <focusedlayout height="44" width="800">
                <!-- Gold outer rectangle = 4px border on all 4 sides -->
                <control type="image">
                    <left>0</left><top>2</top><width>800</width><height>40</height>
                    <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
                </control>
                <!-- Dark inner fill, inset by 4px = leaves the gold border -->
                <control type="image">
                    <left>4</left><top>6</top><width>792</width><height>32</height>
                    <texture>black-back.png</texture><colordiffuse>FF0d1117</colordiffuse>
                </control>
                <control type="label">
                    <left>16</left><top>2</top><width>500</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFFFD700</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
                <control type="label">
                    <left>520</left><top>2</top><width>264</width><height>40</height>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[ListItem.Label2]</label>
                    <align>right</align><aligny>center</aligny>
                </control>
            </focusedlayout>
            <content/>
        </control>

        <!-- ===== Description bar (footer) ===== -->
        <control type="image">
            <left>40</left><top>580</top><width>1200</width><height>48</height>
            <texture>black-back.png</texture><colordiffuse>CC000000</colordiffuse>
        </control>
        <control type="image">
            <left>40</left><top>580</top><width>3</width><height>48</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>
        <control type="textbox" id="400">
            <left>60</left><top>588</top><width>1160</width><height>36</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <align>left</align>
            <autoscroll time="3000" delay="5000" repeat="5000">true</autoscroll>
            <label>Select a setting to edit it.</label>
        </control>

        <control type="label">
            <left>60</left><top>645</top><width>500</width><height>28</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>SALTS  |  Stream All The Sources</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <!-- Action buttons -->
        <control type="button" id="302">
            <left>820</left><top>644</top><width>120</width><height>32</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <focusedcolor>FF0d1117</focusedcolor>
            <align>center</align><aligny>center</aligny>
            <label>Search</label>
            <texturenofocus colordiffuse="CC000000">black-back.png</texturenofocus>
            <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
            <onleft>100</onleft>
            <onright>301</onright>
            <onup>200</onup>
            <ondown>302</ondown>
        </control>
        <control type="button" id="301">
            <left>950</left><top>644</top><width>140</width><height>32</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <focusedcolor>FF0d1117</focusedcolor>
            <align>center</align><aligny>center</aligny>
            <label>Reset Category</label>
            <texturenofocus colordiffuse="CC000000">black-back.png</texturenofocus>
            <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
            <onleft>302</onleft>
            <onright>300</onright>
            <onup>200</onup>
            <ondown>301</ondown>
        </control>
        <control type="button" id="300">
            <left>1100</left><top>644</top><width>120</width><height>32</height>
            <font>font12</font>
            <textcolor>FF0d1117</textcolor>
            <focusedcolor>FF0d1117</focusedcolor>
            <align>center</align><aligny>center</aligny>
            <label>Close</label>
            <texturenofocus colordiffuse="FFFFD700">black-back.png</texturenofocus>
            <texturefocus colordiffuse="FFE8B923">black-back.png</texturefocus>
            <onleft>301</onleft>
            <onright>100</onright>
            <onup>200</onup>
            <ondown>300</ondown>
        </control>
    </controls>
</window>
