<?xml version="1.0" encoding="UTF-8"?>
<!--
    SALTS - Salts-style Metadata Window

    Rendered by salts_lib.salts_context.SaltsMetaWindow.

    Reference resolution: 1280x720

    Control IDs (must stay in sync with Python):
        110  Backdrop image (fanart)
        111  Poster image
        120  Title (with year)
        121  Tagline
        122  Meta line  (date | runtime | status)
        123  Rating line (stars + vote count)
        124  Genres
        130  Plot / overview
        200  Tab content list

        301  Tab: Info
        302  Tab: Cast
        303  Tab: Similar
        304  Tab: Trailers

        401  Action: Play
        402  Action: Add to Favorites
        403  Action: Trakt Watchlist
        404  Action: Close
-->
<window type="dialog" id="13123">
    <defaultcontrol always="true">301</defaultcontrol>
    <coordinates>
        <system>1</system>
        <posx>0</posx><posy>0</posy>
    </coordinates>

    <animation effect="fade" time="220">WindowOpen</animation>
    <animation effect="fade" time="180">WindowClose</animation>

    <controls>
        <!-- ===== Backdrop ===== -->
        <control type="image" id="110">
            <left>0</left><top>0</top>
            <width>1280</width><height>720</height>
            <texture fallback="../../../../fanart.jpg">../../../../fanart.jpg</texture>
            <aspectratio>scale</aspectratio>
        </control>

        <!-- Dark scrim -->
        <control type="image">
            <left>0</left><top>0</top><width>1280</width><height>720</height>
            <texture>black-back.png</texture>
            <colordiffuse>E60d1117</colordiffuse>
            <aspectratio>stretch</aspectratio>
        </control>

        <!-- Top gold accent -->
        <control type="image">
            <left>0</left><top>0</top><width>1280</width><height>3</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <!-- SALTS brand top-left -->
        <control type="image">
            <left>40</left><top>20</top><width>34</width><height>34</height>
            <texture>../../../../icon.png</texture>
            <aspectratio>keep</aspectratio>
        </control>
        <control type="label">
            <left>86</left><top>22</top><width>400</width><height>30</height>
            <font>font13</font>
            <textcolor>FFFFD700</textcolor>
            <label>SALTS  ·  INFO</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <!-- ===== Poster (left column) ===== -->
        <control type="image" id="111">
            <left>40</left><top>70</top><width>260</width><height>390</height>
            <texture fallback="../../../../icon.png">../../../../icon.png</texture>
            <aspectratio>scale</aspectratio>
            <bordertexture border="2" colordiffuse="FFFFD700">black-back.png</bordertexture>
            <bordersize>2</bordersize>
        </control>

        <!-- ===== Title block (right of poster) ===== -->
        <control type="label" id="120">
            <left>320</left><top>70</top><width>920</width><height>42</height>
            <font>font13</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>Title</label>
            <align>left</align><aligny>center</aligny>
            <wrapmultiline>false</wrapmultiline>
        </control>

        <control type="label" id="121">
            <left>320</left><top>116</top><width>920</width><height>24</height>
            <font>font11</font>
            <textcolor>FFFFD700</textcolor>
            <label>tagline</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <control type="label" id="122">
            <left>320</left><top>146</top><width>920</width><height>24</height>
            <font>font11</font>
            <textcolor>FF8b949e</textcolor>
            <label>meta</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <control type="label" id="123">
            <left>320</left><top>174</top><width>920</width><height>24</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>rating</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <control type="label" id="124">
            <left>320</left><top>202</top><width>920</width><height>24</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>genres</label>
            <align>left</align><aligny>center</aligny>
        </control>

        <!-- Plot card -->
        <control type="image">
            <left>320</left><top>234</top><width>920</width><height>120</height>
            <texture>black-back.png</texture>
            <colordiffuse>DD0d1117</colordiffuse>
        </control>
        <control type="image">
            <left>320</left><top>234</top><width>4</width><height>120</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>
        <control type="label" id="130">
            <left>340</left><top>244</top><width>884</width><height>100</height>
            <font>font11</font>
            <textcolor>FFE6EDF3</textcolor>
            <label>plot</label>
            <align>left</align><aligny>top</aligny>
            <wrapmultiline>true</wrapmultiline>
        </control>

        <!-- ===== Tab strip ===== -->
        <control type="group">
            <left>320</left><top>370</top>
            <control type="button" id="301">
                <left>0</left><top>0</top><width>180</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Info</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>404</onleft>
                <onright>302</onright>
                <onup>200</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="302">
                <left>188</left><top>0</top><width>180</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Cast</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>301</onleft>
                <onright>303</onright>
                <onup>200</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="303">
                <left>376</left><top>0</top><width>180</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Similar</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>302</onleft>
                <onright>304</onright>
                <onup>200</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="304">
                <left>564</left><top>0</top><width>180</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Trailers</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>303</onleft>
                <onright>401</onright>
                <onup>200</onup>
                <ondown>200</ondown>
            </control>
        </control>

        <!-- ===== Tab content list ===== -->
        <control type="image">
            <left>320</left><top>416</top><width>920</width><height>238</height>
            <texture>black-back.png</texture>
            <colordiffuse>CC0d1117</colordiffuse>
        </control>
        <control type="image">
            <left>320</left><top>416</top><width>920</width><height>2</height>
            <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
        </control>

        <control type="list" id="200">
            <left>328</left><top>424</top><width>904</width><height>222</height>
            <onleft>404</onleft>
            <onright>401</onright>
            <onup>301</onup>
            <ondown>401</ondown>
            <pagecontrol>-</pagecontrol>
            <scrolltime>180</scrolltime>

            <itemlayout height="44" width="904">
                <control type="image">
                    <left>4</left><top>4</top><width>36</width><height>36</height>
                    <texture fallback="../../../../icon.png">$INFO[ListItem.Icon]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>48</left><top>4</top><width>852</width><height>36</height>
                    <font>font11</font>
                    <textcolor>FFE6EDF3</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </itemlayout>

            <focusedlayout height="44" width="904">
                <control type="image">
                    <left>0</left><top>0</top><width>904</width><height>44</height>
                    <texture>black-back.png</texture><colordiffuse>FFFFD700</colordiffuse>
                </control>
                <control type="image">
                    <left>2</left><top>2</top><width>900</width><height>40</height>
                    <texture>black-back.png</texture><colordiffuse>FF0d1117</colordiffuse>
                </control>
                <control type="image">
                    <left>6</left><top>6</top><width>36</width><height>32</height>
                    <texture fallback="../../../../icon.png">$INFO[ListItem.Icon]</texture>
                    <aspectratio>keep</aspectratio>
                </control>
                <control type="label">
                    <left>50</left><top>4</top><width>848</width><height>36</height>
                    <font>font11</font>
                    <textcolor>FFFFD700</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align><aligny>center</aligny>
                </control>
            </focusedlayout>
            <content/>
        </control>

        <!-- ===== Action buttons ===== -->
        <control type="group">
            <left>320</left><top>666</top>
            <control type="button" id="401">
                <left>0</left><top>0</top><width>170</width><height>36</height>
                <font>font12</font>
                <textcolor>FF0d1117</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>▶  Play</label>
                <texturenofocus colordiffuse="FFFFD700">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFE655">black-back.png</texturefocus>
                <onleft>200</onleft>
                <onright>402</onright>
                <onup>301</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="402">
                <left>178</left><top>0</top><width>200</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>+ Favorites</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>401</onleft>
                <onright>403</onright>
                <onup>302</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="403">
                <left>386</left><top>0</top><width>220</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Trakt Watchlist</label>
                <texturenofocus colordiffuse="FF21262d">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>402</onleft>
                <onright>404</onright>
                <onup>303</onup>
                <ondown>200</ondown>
            </control>
            <control type="button" id="404">
                <left>770</left><top>0</top><width>150</width><height>36</height>
                <font>font12</font>
                <textcolor>FFE6EDF3</textcolor>
                <focusedcolor>FF0d1117</focusedcolor>
                <align>center</align><aligny>center</aligny>
                <label>Close</label>
                <texturenofocus colordiffuse="FF8b949e">black-back.png</texturenofocus>
                <texturefocus colordiffuse="FFFFD700">black-back.png</texturefocus>
                <onleft>403</onleft>
                <onright>301</onright>
                <onup>304</onup>
                <ondown>200</ondown>
            </control>
        </control>
    </controls>
</window>
