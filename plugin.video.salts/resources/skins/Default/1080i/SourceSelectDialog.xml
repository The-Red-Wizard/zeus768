            <left>160</left>
            <top>80</top>
            <width>1600</width>
            <height>920</height>
            <texture colordiffuse="F0101820">-</texture>
        </control>

        <!-- Header bar -->
        <control type="image">
            <left>160</left>
            <top>80</top>
            <width>1600</width>
            <height>70</height>
            <texture colordiffuse="FF1A2636">-</texture>
        </control>

        <!-- Header label -->
        <control type="label" id="100">
            <left>180</left>
            <top>82</top>
            <width>1200</width>
            <height>66</height>
            <font>font14</font>
            <textcolor>FFFFFFFF</textcolor>
            <label>SALTS Source Selection</label>
            <align>left</align>
            <aligny>center</aligny>
        </control>

        <!-- Close button label -->
        <control type="label" id="101">
            <left>1580</left>
            <top>82</top>
            <width>160</width>
            <height>66</height>
            <font>font13</font>
            <textcolor>FF888888</textcolor>
            <label>[ESC] Close</label>
            <align>right</align>
            <aligny>center</aligny>
        </control>

        <!-- Quality summary bar -->
        <control type="label" id="200">
            <left>180</left>
            <top>156</top>
            <width>1560</width>
            <height>36</height>
            <font>font12</font>
            <textcolor>FF99AACC</textcolor>
            <label>Loading sources...</label>
            <align>left</align>
            <aligny>center</aligny>
        </control>

        <!-- ============ BENTO GRID ============ -->
        <!-- 
             Grid layout: Panel list with varied item heights
             Using a FixedList so we can control rendering per-item
        -->
        <control type="panel" id="6000">
            <left>170</left>
            <top>200</top>
            <width>1580</width>
            <height>770</height>
            <onleft>6000</onleft>
            <onright>6000</onright>
            <onup>6000</onup>
            <ondown>6000</ondown>
            <viewtype label="Bento">panel</viewtype>
            <orientation>vertical</orientation>
            <pagecontrol>6001</pagecontrol>
            <scrolltime>200</scrolltime>
            <itemlayout width="1560" height="90">
                <!-- Card background -->
                <control type="image">
                    <left>0</left>
                    <top>4</top>
                    <width>1560</width>
                    <height>82</height>
                    <texture colordiffuse="FF1C2B3A">-</texture>
                </control>
                <!-- Quality badge -->
                <control type="image">
                    <left>8</left>
                    <top>10</top>
                    <width>100</width>
                    <height>70</height>
                    <texture colordiffuse="$INFO[ListItem.Property(badge_color)]">-</texture>
                </control>
                <control type="label">
                    <left>8</left>
                    <top>10</top>
                    <width>100</width>
                    <height>70</height>
                    <font>font14_title</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <label>$INFO[ListItem.Property(quality)]</label>
                    <align>center</align>
                    <aligny>center</aligny>
                </control>
                <!-- Cached / Free tag -->
                <control type="label">
                    <left>120</left>
                    <top>10</top>
                    <width>120</width>
                    <height>34</height>
                    <font>font12</font>
                    <textcolor>$INFO[ListItem.Property(tag_color)]</textcolor>
                    <label>$INFO[ListItem.Property(tag)]</label>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Scraper name -->
                <control type="label">
                    <left>250</left>
                    <top>10</top>
                    <width>400</width>
                    <height>34</height>
                    <font>font13</font>
                    <textcolor>FFCCDDEE</textcolor>
                    <label>$INFO[ListItem.Property(scraper)]</label>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Title -->
                <control type="label">
                    <left>120</left>
                    <top>44</top>
                    <width>900</width>
                    <height>34</height>
                    <font>font12</font>
                    <textcolor>FF8899AA</textcolor>
                    <label>$INFO[ListItem.Label]</label>
                    <align>left</align>
                    <aligny>center</aligny>
                </control>
                <!-- Seeds -->
                <control type="label">
                    <left>1100</left>
                    <top>10</top>
                    <width>200</width>
                    <height>34</height>
                    <font>font12</font>
                    <textcolor>FF55CC55</textcolor>
                    <label>$INFO[ListItem.Property(seeds)]</label>
                    <align>right</align>
                    <aligny>center</aligny>
